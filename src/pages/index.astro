---
import { getCollection } from "astro:content";
import { getRelativeLocaleUrl } from "astro:i18n";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Card from "@/components/Card.astro";
import LinkButton from "@/components/LinkButton.astro";
import { getSortedPosts } from "@/utils/getSortedPosts";
import { useTranslations } from "@/i18n";
import config from "@/config";

const locale = Astro.currentLocale ?? config.site.lang;
const t = useTranslations(locale);

const posts = await getCollection("posts");
const sortedPosts = getSortedPosts(posts);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);
const homePath = getRelativeLocaleUrl(locale, "");

const projects = [
  {
    title: "Prompt-to-Ontology",
    description:
      "A public experiment turning messy requirements and business concepts into ontology assets: entities, relationships, constraints, and action-ready knowledge graphs for enterprise AI systems.",
    status: "Public",
    href: getRelativeLocaleUrl(locale, "projects/prompt-to-ontology"),
  },
  {
    title: "AI PM Operating Playbook",
    description:
      "A methodology-driven toolkit that turns ambiguous AI product ideas into structured product briefs, workflow specifications, evaluation plans, and coding-agent handoff materials.",
    status: "Public Tool",
    href: "https://wenhaoyu-bryan.github.io/AI-PM-Operating-Playbook/",
  },
  {
    title: "Vibe Coding Prototype Lab",
    description:
      "A public lab showing how PM-led LLM pair programming can turn ambiguous ideas into prototypes, specs, and reusable product workflows.",
    status: "Public",
    href: getRelativeLocaleUrl(locale, "projects/vibe-coding-prototype-lab"),
  },
  {
    title: "SEO/GEO Growth Experiments",
    description:
      "Experiments on content systems, B2B websites, and AI-search-aware growth loops — connecting SEO fundamentals with GEO visibility.",
    status: "Ongoing",
    href: getRelativeLocaleUrl(locale, "growth-lab"),
  },
];

const topics = [
  {
    title: "Agentic Workflows",
    description: "Designing agent systems with tools, memory, and governance.",
  },
  {
    title: "Ontology-Driven AI Products",
    description:
      "Using knowledge graphs and structured ontologies to make enterprise AI reliable.",
  },
  {
    title: "Harness Engineering",
    description:
      "Designing the context, tools, constraints, and feedback systems that guide AI coding agents.",
  },
  {
    title: "Loop Engineering",
    description:
      "Designing the feedback loops through which AI products, teams, and delivery artifacts improve over iterations.",
  },
  {
    title: "Vibe Coding for PMs",
    description:
      "PM-led, coding-agent-assisted prototyping for early discovery and workflow validation.",
  },
  {
    title: "Industrial & B2B AI",
    description:
      "Enterprise AI adoption, industrial operations, and B2B product contexts.",
  },
];
---

<Layout>
  <Header />
  <main
    id="main-content"
    data-layout="index"
    data-home-path={homePath}
    class="app-layout"
  >
    <!-- Hero -->
    <section class="border-border border-b pt-8 pb-10 sm:pt-12 sm:pb-14">
      <h1 class="my-4 text-4xl font-bold tracking-tight sm:my-6 sm:text-5xl">
        Wenhao Yu
      </h1>
      <p class="text-lg font-medium sm:text-xl">
        AI Product Manager building agentic workflows, ontology-driven systems,
        and AI-native product tools.
      </p>
      <p class="text-muted-foreground mt-3 max-w-2xl">
        I turn ambiguous business problems into structured product concepts,
        interactive prototypes, and reusable delivery systems.
      </p>
      <div class="mt-6 flex flex-wrap gap-3">
        <a
          href={getRelativeLocaleUrl(locale, "projects")}
          class="bg-accent text-accent-foreground inline-flex items-center gap-1.5 rounded-md px-5 py-2.5 text-sm font-medium transition-opacity hover:opacity-90"
        >
          View Projects
          <IconArrowRight class="size-4" />
        </a>
        <a
          href="https://wenhaoyu-bryan.github.io/AI-PM-Operating-Playbook/"
          target="_blank"
          rel="noopener noreferrer"
          class="border-border text-foreground hover:bg-accent/10 inline-flex items-center gap-1.5 rounded-md border px-5 py-2.5 text-sm font-medium transition-colors"
        >
          Open AI PM Operating Playbook ↗
        </a>
        <a
          href={getRelativeLocaleUrl(locale, "posts")}
          class="border-border text-foreground hover:bg-accent/10 inline-flex items-center gap-1.5 rounded-md border px-5 py-2.5 text-sm font-medium transition-colors"
        >
          Read My Writing
        </a>
      </div>
    </section>

    <!-- Featured Projects -->
    <section class="border-border border-b py-10 sm:py-14">
      <h2 class="text-2xl font-semibold tracking-wide">Featured Projects</h2>
      <div class="mt-6 grid gap-4 sm:grid-cols-2">
        {
          projects.map(project => (
            <a
              href={project.href}
              class="border-border group hover:bg-accent/5 rounded-lg border p-5 transition-colors"
              {...(project.href.startsWith("http")
                ? { target: "_blank", rel: "noopener noreferrer" }
                : {})}
            >
              <div class="flex items-center justify-between">
                <h3 class="group-hover:text-accent text-lg font-medium">
                  {project.title}
                </h3>
                <span class="text-muted-foreground rounded-full border px-2.5 py-0.5 text-xs">
                  {project.status}
                </span>
              </div>
              <p class="text-muted-foreground mt-2 text-sm">
                {project.description}
              </p>
            </a>
          ))
        }
      </div>
    </section>

    <!-- Featured Content -->
    <section class="border-border border-b py-10 sm:py-14">
      <h2 class="text-2xl font-semibold tracking-wide">Featured</h2>
      <p class="text-muted-foreground mt-2 text-sm">
        Start here — the strongest signals from my work.
      </p>
      <div class="mt-6 flex flex-wrap gap-3">
        <a
          href={getRelativeLocaleUrl(locale, "posts/building-ontology-os")}
          class="border-border text-foreground hover:bg-accent/10 inline-flex items-center gap-1.5 rounded-md border px-4 py-2 text-sm font-medium transition-colors"
        >
          Building Ontology OS
        </a>
        <a
          href={getRelativeLocaleUrl(locale, "playbook/harness-engineering")}
          class="border-border text-foreground hover:bg-accent/10 inline-flex items-center gap-1.5 rounded-md border px-4 py-2 text-sm font-medium transition-colors"
        >
          Harness Engineering
        </a>
        <a
          href={getRelativeLocaleUrl(locale, "playbook/ai-native-prd")}
          class="border-border text-foreground hover:bg-accent/10 inline-flex items-center gap-1.5 rounded-md border px-4 py-2 text-sm font-medium transition-colors"
        >
          AI-Native PRD
        </a>
        <a
          href={getRelativeLocaleUrl(locale, "playbook/loop-engineering")}
          class="border-border text-foreground hover:bg-accent/10 inline-flex items-center gap-1.5 rounded-md border px-4 py-2 text-sm font-medium transition-colors"
        >
          Loop Engineering
        </a>
        <a
          href={getRelativeLocaleUrl(
            locale,
            "projects/vibe-coding-prototype-lab"
          )}
          class="border-border text-foreground hover:bg-accent/10 inline-flex items-center gap-1.5 rounded-md border px-4 py-2 text-sm font-medium transition-colors"
        >
          Vibe Coding Prototype Lab
        </a>
        <a
          href={getRelativeLocaleUrl(locale, "playbook/seo-to-geo")}
          class="border-border text-foreground hover:bg-accent/10 inline-flex items-center gap-1.5 rounded-md border px-4 py-2 text-sm font-medium transition-colors"
        >
          SEO to GEO
        </a>
        <a
          href={getRelativeLocaleUrl(locale, "projects/prompt-to-ontology")}
          class="border-border text-foreground hover:bg-accent/10 inline-flex items-center gap-1.5 rounded-md border px-4 py-2 text-sm font-medium transition-colors"
        >
          Prompt-to-Ontology
        </a>
      </div>
    </section>

    <!-- What I Work On -->
    <section class="border-border border-b py-10 sm:py-14">
      <h2 class="text-2xl font-semibold tracking-wide">What I Work On</h2>
      <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {
          topics.map(topic => (
            <div class="border-border rounded-lg border p-5">
              <h3 class="font-medium">{topic.title}</h3>
              <p class="text-muted-foreground mt-1.5 text-sm">
                {topic.description}
              </p>
            </div>
          ))
        }
      </div>
    </section>

    <!-- Latest Writing -->
    {
      recentPosts.length > 0 && (
        <section class="border-border border-b py-10 sm:py-14">
          <h2 class="text-2xl font-semibold tracking-wide">
            {t.home.recentPosts}
          </h2>
          <ul class="mt-4">
            {recentPosts.slice(0, 3).map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
          <div class="mt-6">
            <LinkButton href={getRelativeLocaleUrl(locale, "posts")}>
              {t.home.allPosts}
              <IconArrowRight class="inline-block rtl:-rotate-180" />
            </LinkButton>
          </div>
        </section>
      )
    }

    <!-- Contact CTA -->
    <section id="contact" class="py-10 sm:py-14">
      <h2 class="text-2xl font-semibold tracking-wide">Connect</h2>
      <p class="text-muted-foreground mt-2 max-w-xl">
        Interested in AI product collaboration, ontology-driven systems, or
        growth experiments? Let's talk.
      </p>
      <div class="mt-5 flex flex-wrap gap-3">
        <button
          type="button"
          class="border-border text-foreground hover:bg-accent/10 inline-flex items-center gap-1.5 rounded-md border px-4 py-2 text-sm font-medium transition-colors cursor-pointer"
          data-copy-email="wenhaoyu.bryan@gmail.com"
        >
          Email
        </button>
        <a
          href="https://github.com/wenhaoyu-bryan"
          class="border-border text-foreground hover:bg-accent/10 inline-flex items-center gap-1.5 rounded-md border px-4 py-2 text-sm font-medium transition-colors"
          target="_blank"
          rel="noopener noreferrer"
        >
          GitHub
        </a>
        <a
          href="https://linkedin.com/in/wenhaoyu-bryan/"
          class="border-border text-foreground hover:bg-accent/10 inline-flex items-center gap-1.5 rounded-md border px-4 py-2 text-sm font-medium transition-colors"
          target="_blank"
          rel="noopener noreferrer"
        >
          LinkedIn
        </a>
        <a
          href="https://x.com/WENHAOYU8"
          class="border-border text-foreground hover:bg-accent/10 inline-flex items-center gap-1.5 rounded-md border px-4 py-2 text-sm font-medium transition-colors"
          target="_blank"
          rel="noopener noreferrer"
        >
          X
        </a>
        <a
          href="https://medium.com/@bryanyuwh"
          class="border-border text-foreground hover:bg-accent/10 inline-flex items-center gap-1.5 rounded-md border px-4 py-2 text-sm font-medium transition-colors"
          target="_blank"
          rel="noopener noreferrer"
        >
          Medium
        </a>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset;
    const baseRoot = import.meta.env.BASE_URL.replace(/\/?$/, "/");
    if (indexLayout?.layout) {
      sessionStorage.setItem("backUrl", indexLayout.homePath ?? baseRoot);
    }

    document.querySelectorAll<HTMLButtonElement>("[data-copy-email]").forEach(btn => {
      btn.addEventListener("click", async () => {
        const email = btn.dataset.copyEmail;
        if (!email) return;
        try {
          await navigator.clipboard.writeText(email);
          const original = btn.textContent;
          btn.textContent = "Copied!";
          setTimeout(() => { btn.textContent = original; }, 2000);
        } catch {
          window.location.href = `mailto:${email}`;
        }
      });
    });
  });
</script>
