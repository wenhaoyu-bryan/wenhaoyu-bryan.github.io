---
import { getCollection } from "astro:content";
import { getRelativeLocaleUrl } from "astro:i18n";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Card from "@/components/Card.astro";
import LinkButton from "@/components/LinkButton.astro";
import { getSortedPosts } from "@/utils/getSortedPosts";
import { useTranslations } from "@/i18n";
import config from "@/config";
import {
  Network,
  Book,
  Code,
  TrendingUp,
  Bot,
  Database,
  Settings,
  RefreshCw,
  Wand2,
  Building2,
} from "lucide-astro";
import { getProjects } from "@/data/projects";
import AskAI from "@/components/AskAI.astro";

const locale = Astro.currentLocale ?? config.site.lang;
const t = useTranslations(locale);

const posts = await getCollection("posts");
const sortedPosts = getSortedPosts(posts);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);
const homePath = getRelativeLocaleUrl(locale, "");

const projects = getProjects(locale);

const topics = [
  {
    title: "Agentic Workflows",
    description: "Designing agent systems with tools, memory, and governance.",
    icon: "Bot",
  },
  {
    title: "Ontology-Driven AI Products",
    description:
      "Using knowledge graphs and structured ontologies to make enterprise AI reliable.",
    icon: "Database",
  },
  {
    title: "Harness Engineering",
    description:
      "Designing the context, tools, constraints, and feedback systems that guide AI coding agents.",
    icon: "Settings",
  },
  {
    title: "Loop Engineering",
    description:
      "Designing the feedback loops through which AI products, teams, and delivery artifacts improve over iterations.",
    icon: "RefreshCw",
  },
  {
    title: "Vibe Coding for PMs",
    description:
      "PM-led, coding-agent-assisted prototyping for early discovery and workflow validation.",
    icon: "Wand2",
  },
  {
    title: "Industrial & B2B AI",
    description:
      "Enterprise AI adoption, industrial operations, and B2B product contexts.",
    icon: "Building2",
  },
];
---

<Layout>
  <Header />
  <main
    id="main-content"
    data-layout="index"
    data-home-path={homePath}
    class="app-layout animate-main"
  >
    <!-- Hero -->
    <section class="border-border border-b pt-8 pb-10 sm:pt-12 sm:pb-14">
      <div
        class="flex flex-col gap-6 sm:flex-row sm:items-center sm:justify-between"
      >
        <div class="max-w-2xl">
          <p
            class="border-border text-muted-foreground mb-4 inline-flex items-center gap-2 rounded-full border px-3 py-1 text-xs font-medium"
          >
            <span class="inline-block size-1.5 rounded-full bg-green-500"
            ></span>
            Open to AI PM roles, collaborations, and early-stage ideas —
            <a
              href="#contact"
              class="text-foreground hover:text-accent underline decoration-dashed underline-offset-4"
              >get in touch</a
            >
          </p>
          <h1 class="text-4xl font-bold tracking-tight sm:text-5xl">
            Wenhao Yu
          </h1>
          <div
            class="bg-accent mt-5 h-0.5 w-16 origin-left animate-[slideIn_600ms_ease-out_200ms_forwards]"
            style="transform: scaleX(0);"
          >
          </div>
          <p class="mt-4 text-lg font-medium sm:text-xl">
            AI Product Manager building agentic workflows, ontology-driven
            systems, and AI-native product tools.
          </p>
          <p class="text-muted-foreground mt-3 max-w-2xl">
            I turn ambiguous business problems into structured product concepts,
            interactive prototypes, and reusable delivery systems.
          </p>
          <p class="mt-3 text-sm">
            <a
              href={getRelativeLocaleUrl(locale, "now")}
              class="text-accent hover:underline"
            >
              → What I'm doing now
            </a>
          </p>
          <p class="text-muted-foreground mt-4 text-sm">Start here →</p>
          <div class="mt-2 flex flex-wrap gap-3">
            <a
              href={getRelativeLocaleUrl(locale, "projects")}
              class="bg-accent text-accent-foreground inline-flex items-center gap-1.5 rounded-md px-5 py-2.5 text-sm font-medium transition-all hover:scale-105 hover:shadow-[0_2px_8px_rgba(0,0,0,0.08)] dark:hover:shadow-[0_2px_8px_rgba(0,0,0,0.3)]"
            >
              View Projects
              <IconArrowRight class="size-4" />
            </a>
            <a
              href="https://wenhaoyu-bryan.github.io/AI-PM-Operating-Playbook/"
              target="_blank"
              rel="noopener noreferrer"
              class="border-border text-foreground hover:bg-accent/10 inline-flex items-center gap-1.5 rounded-md border px-5 py-2.5 text-sm font-medium transition-colors"
            >
              Open AI PM Operating Playbook ↗
            </a>
            <a
              href={getRelativeLocaleUrl(locale, "posts")}
              class="border-border text-foreground hover:bg-accent/10 inline-flex items-center gap-1.5 rounded-md border px-5 py-2.5 text-sm font-medium transition-colors"
            >
              Read My Writing
            </a>
          </div>
        </div>
        <img
          src="/profile-avatar.jpg"
          alt="Wenhao Yu - AI Product Manager"
          width="152"
          height="152"
          class="border-border bg-muted/30 size-28 rounded-full border object-cover sm:size-36"
          loading="eager"
          decoding="async"
        />
      </div>
    </section>

    <!-- Featured Projects -->
    <section class="border-border border-b py-10 sm:py-14">
      <h2 class="text-2xl font-semibold tracking-wide">Featured Projects</h2>
      <div class="mt-6 grid gap-4 sm:grid-cols-2">
        {
          projects.map(project => {
            const IconComponent =
              project.icon === "Network"
                ? Network
                : project.icon === "Book"
                  ? Book
                  : project.icon === "Code"
                    ? Code
                    : TrendingUp;
            // Shades chosen to meet WCAG AA contrast in both themes:
            // *-700 on the light card bg, *-400 on the dark card bg.
            const statusColor =
              project.status === "Public"
                ? "border-green-500 text-green-700 dark:text-green-400"
                : project.status === "Public Tool"
                  ? "border-blue-500 text-blue-700 dark:text-blue-400"
                  : "border-orange-500 text-orange-700 dark:text-orange-400";
            return (
              <a
                href={project.href}
                class="border-border group hover:bg-accent/5 hover:border-accent rounded-lg border p-5 transition-all duration-200 hover:-translate-y-1 hover:shadow-[0_4px_12px_rgba(0,0,0,0.06)] dark:hover:shadow-[0_4px_12px_rgba(0,0,0,0.3)]"
                {...(project.href.startsWith("http")
                  ? { target: "_blank", rel: "noopener noreferrer" }
                  : {})}
              >
                <div class="flex items-start gap-3">
                  <IconComponent
                    size={24}
                    strokeWidth={2}
                    class="text-foreground group-hover:text-accent mt-0.5 flex-shrink-0 transition-colors"
                  />
                  <div class="min-w-0 flex-1">
                    <div class="flex items-start justify-between gap-2">
                      <h3 class="group-hover:text-accent text-lg font-medium transition-colors">
                        {project.title}
                      </h3>
                      <span
                        class={`flex flex-shrink-0 items-center gap-1 rounded-full border px-2.5 py-0.5 text-xs ${statusColor}`}
                      >
                        <span class="h-1.5 w-1.5 rounded-full bg-current" />
                        {project.status}
                      </span>
                    </div>
                    <p class="text-muted-foreground mt-2 text-sm">
                      {project.description}
                    </p>
                  </div>
                </div>
              </a>
            );
          })
        }
      </div>
    </section>

    <!-- Featured Content -->
    <section class="border-border border-b py-10 sm:py-14">
      <h2 class="text-2xl font-semibold tracking-wide">Featured</h2>
      <p class="text-muted-foreground mt-2 text-sm">
        Start here — the strongest signals from my work.
      </p>
      <div class="mt-6 flex flex-wrap gap-3">
        <a
          href={getRelativeLocaleUrl(locale, "posts/building-ontology-os")}
          class="border-border text-foreground hover:bg-accent/10 inline-flex items-center gap-1.5 rounded-md border px-4 py-2 text-sm font-medium transition-colors"
        >
          Building Ontology OS
        </a>
        <a
          href={getRelativeLocaleUrl(locale, "playbook/harness-engineering")}
          class="border-border text-foreground hover:bg-accent/10 inline-flex items-center gap-1.5 rounded-md border px-4 py-2 text-sm font-medium transition-colors"
        >
          Harness Engineering
        </a>
        <a
          href={getRelativeLocaleUrl(locale, "playbook/ai-native-prd")}
          class="border-border text-foreground hover:bg-accent/10 inline-flex items-center gap-1.5 rounded-md border px-4 py-2 text-sm font-medium transition-colors"
        >
          AI-Native PRD
        </a>
        <a
          href={getRelativeLocaleUrl(locale, "playbook/loop-engineering")}
          class="border-border text-foreground hover:bg-accent/10 inline-flex items-center gap-1.5 rounded-md border px-4 py-2 text-sm font-medium transition-colors"
        >
          Loop Engineering
        </a>
        <a
          href={getRelativeLocaleUrl(
            locale,
            "projects/vibe-coding-prototype-lab"
          )}
          class="border-border text-foreground hover:bg-accent/10 inline-flex items-center gap-1.5 rounded-md border px-4 py-2 text-sm font-medium transition-colors"
        >
          Vibe Coding Prototype Lab
        </a>
        <a
          href={getRelativeLocaleUrl(locale, "playbook/seo-to-geo")}
          class="border-border text-foreground hover:bg-accent/10 inline-flex items-center gap-1.5 rounded-md border px-4 py-2 text-sm font-medium transition-colors"
        >
          SEO to GEO
        </a>
        <a
          href={getRelativeLocaleUrl(locale, "projects/prompt-to-ontology")}
          class="border-border text-foreground hover:bg-accent/10 inline-flex items-center gap-1.5 rounded-md border px-4 py-2 text-sm font-medium transition-colors"
        >
          Prompt-to-Ontology
        </a>
      </div>
    </section>

    <!-- What I Work On -->
    <section class="border-border border-b py-10 sm:py-14">
      <h2 class="text-2xl font-semibold tracking-wide">What I Work On</h2>
      <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {
          topics.map(topic => {
            const IconComponent =
              topic.icon === "Bot"
                ? Bot
                : topic.icon === "Database"
                  ? Database
                  : topic.icon === "Settings"
                    ? Settings
                    : topic.icon === "RefreshCw"
                      ? RefreshCw
                      : topic.icon === "Wand2"
                        ? Wand2
                        : Building2;
            return (
              <div class="border-border hover:bg-accent/5 hover:border-accent/30 group rounded-lg border p-5 transition-all duration-200">
                <div class="flex items-start gap-3">
                  <IconComponent
                    size={24}
                    strokeWidth={2}
                    class="text-foreground group-hover:text-accent mt-0.5 flex-shrink-0 transition-colors"
                  />
                  <div>
                    <h3 class="font-medium">{topic.title}</h3>
                    <p class="text-muted-foreground mt-1.5 text-sm">
                      {topic.description}
                    </p>
                  </div>
                </div>
              </div>
            );
          })
        }
      </div>
      <div class="mt-8">
        <h3 class="text-muted-foreground mb-3 text-sm font-medium">Toolbox</h3>
        <div class="flex flex-wrap gap-2">
          {
            [
              "Claude Code",
              "TypeScript",
              "Python",
              "Neo4j",
              "Astro",
              "React",
              "Node.js",
              "Figma",
              "Notion",
              "Obsidian",
            ].map(skill => (
              <span class="border-border bg-muted/30 hover:bg-accent/10 hover:border-accent inline-flex cursor-default items-center gap-1.5 rounded-full border px-3 py-1.5 text-sm transition-all hover:scale-105">
                {skill}
              </span>
            ))
          }
        </div>
        <p class="mt-4 text-sm">
          <a
            href={getRelativeLocaleUrl(locale, "ai-stack")}
            class="text-accent hover:underline"
          >
            How I orchestrate these tools → My AI Stack
          </a>
        </p>
      </div>
    </section>

    <!-- Latest Writing -->
    {
      recentPosts.length > 0 && (
        <section class="border-border border-b py-10 sm:py-14">
          <h2 class="text-2xl font-semibold tracking-wide">
            {t.home.recentPosts}
          </h2>
          <ul class="mt-4">
            {recentPosts.slice(0, 3).map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
          <div class="mt-6">
            <LinkButton href={getRelativeLocaleUrl(locale, "posts")}>
              {t.home.allPosts}
              <IconArrowRight class="inline-block rtl:-rotate-180" />
            </LinkButton>
          </div>
        </section>
      )
    }

    <!-- Contact -->
    <section id="contact" class="py-10 sm:py-14">
      <h2 class="text-2xl font-semibold tracking-wide">Get in Touch</h2>
      <p class="text-muted-foreground mt-2 max-w-xl">
        Interested in AI product collaboration, ontology-driven systems, or
        growth experiments? I'm happy to talk — whether you're hiring, building,
        or just comparing notes.
      </p>
      <div class="mt-5 max-w-xl">
        <AskAI locale={locale} />
      </div>
      <div class="mt-5 flex flex-wrap gap-3">
        <button
          type="button"
          class="bg-accent text-accent-foreground inline-flex cursor-pointer items-center gap-1.5 rounded-md px-5 py-2.5 text-sm font-medium transition-opacity hover:opacity-90"
          data-copy-email="wenhaoyu.bryan@gmail.com"
        >
          Copy Email
        </button>
        <a
          href="https://www.linkedin.com/in/wenhaoyu-bryan/"
          class="border-border text-foreground hover:bg-accent/10 inline-flex items-center gap-1.5 rounded-md border px-4 py-2 text-sm font-medium transition-colors"
          target="_blank"
          rel="noopener noreferrer"
        >
          LinkedIn
        </a>
        <a
          href="https://github.com/wenhaoyu-bryan"
          class="border-border text-foreground hover:bg-accent/10 inline-flex items-center gap-1.5 rounded-md border px-4 py-2 text-sm font-medium transition-colors"
          target="_blank"
          rel="noopener noreferrer"
        >
          GitHub
        </a>
        <a
          href="https://x.com/WENHAOYU8"
          class="border-border text-foreground hover:bg-accent/10 inline-flex items-center gap-1.5 rounded-md border px-4 py-2 text-sm font-medium transition-colors"
          target="_blank"
          rel="noopener noreferrer"
        >
          X
        </a>
        <a
          href="https://medium.com/@bryanyuwh"
          class="border-border text-foreground hover:bg-accent/10 inline-flex items-center gap-1.5 rounded-md border px-4 py-2 text-sm font-medium transition-colors"
          target="_blank"
          rel="noopener noreferrer"
        >
          Medium
        </a>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    document
      .querySelectorAll<HTMLButtonElement>("[data-copy-email]")
      .forEach(btn => {
        btn.addEventListener("click", async () => {
          const email = btn.dataset.copyEmail;
          if (!email) return;
          try {
            await navigator.clipboard.writeText(email);
            const original = btn.textContent;
            btn.textContent = "Copied!";
            setTimeout(() => {
              btn.textContent = original;
            }, 2000);
          } catch {
            window.location.href = `mailto:${email}`;
          }
        });
      });

    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset;
    const baseRoot = import.meta.env.BASE_URL.replace(/\/?$/, "/");
    if (indexLayout?.layout) {
      sessionStorage.setItem("backUrl", indexLayout.homePath ?? baseRoot);
    }

    // Respect users who prefer reduced motion: skip the opacity-0 reveal
    // entirely so content is never hidden behind an animation for them.
    const prefersReducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)"
    ).matches;

    // Initial page load animation (only on first visit to homepage)
    const isHomepage = indexLayout?.layout === "index";
    if (
      !prefersReducedMotion &&
      isHomepage &&
      !sessionStorage.getItem("homeAnimated")
    ) {
      sessionStorage.setItem("homeAnimated", "true");

      const sections = document.querySelectorAll("#main-content > section");
      sections.forEach((section, index) => {
        section.classList.add("opacity-0");
        setTimeout(() => {
          section.classList.add("animate-fadeInUp");
        }, index * 100); // Stagger by 100ms per section
      });
    }

    // Scroll-triggered animation for cards
    const observerOptions = {
      threshold: 0.1,
      rootMargin: "0px 0px -50px 0px",
    };

    const observer = new IntersectionObserver(entries => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add("animate-fadeInUp");
          observer.unobserve(entry.target);
        }
      });
    }, observerOptions);

    // Observe individual cards within sections (only if not already animated from page load)
    if (
      !prefersReducedMotion &&
      (!isHomepage || sessionStorage.getItem("homeAnimated"))
    ) {
      document
        .querySelectorAll("section > div > a, section > div > div")
        .forEach(card => {
          if (
            card.classList.contains("border") ||
            card.parentElement?.classList.contains("grid")
          ) {
            card.classList.add("opacity-0");
            observer.observe(card);
          }
        });
    }
  });
</script>

<style>
  .animate-fadeInUp {
    animation: fadeInUp 0.6s ease-out forwards;
  }
</style>
