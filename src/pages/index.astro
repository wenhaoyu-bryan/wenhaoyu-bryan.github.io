---
import { getCollection } from "astro:content";
import { getRelativeLocaleUrl } from "astro:i18n";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Card from "@/components/Card.astro";
import LinkButton from "@/components/LinkButton.astro";
import { getSortedPosts } from "@/utils/getSortedPosts";
import { useTranslations } from "@/i18n";
import config from "@/config";
import {
  Network,
  Book,
  Code,
  TrendingUp,
  Activity,
  Bot,
  Database,
  Settings,
  Building2,
} from "lucide-astro";
import { getProjects } from "@/data/projects";
import AskAI from "@/components/AskAI.astro";
import ContactRow from "@/components/ContactRow.astro";

const locale = Astro.currentLocale ?? config.site.lang;
const t = useTranslations(locale);

const posts = await getCollection("posts");
const sortedPosts = getSortedPosts(posts);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);
const homePath = getRelativeLocaleUrl(locale, "");

const projects = getProjects(locale);

type Proof = { label: string; href: string; external?: boolean };
type Topic = {
  title: string;
  description: string;
  icon: string;
  subLinks?: { label: string; href: string }[];
  proofs: Proof[];
};

const topics: Topic[] = [
  {
    title: "Agentic Workflows",
    description: "Designing agent systems with tools, memory, and governance.",
    icon: "Bot",
    proofs: [
      {
        label: "Agent Anatomy",
        href: "https://wenhaoyu-bryan.github.io/agent-anatomy/",
        external: true,
      },
    ],
  },
  {
    title: "Ontology-Driven AI Products",
    description:
      "Knowledge graphs and structured ontologies that make enterprise AI reliable.",
    icon: "Database",
    proofs: [
      {
        label: "Prompt-to-Ontology",
        href: getRelativeLocaleUrl(locale, "projects/prompt-to-ontology"),
      },
    ],
  },
  {
    title: "AI-Assisted Delivery",
    description:
      "Harness Engineering, Loop Engineering, and Vibe Coding — the systems through which PMs ship with coding agents.",
    icon: "Settings",
    subLinks: [
      {
        label: "Harness Engineering",
        href: getRelativeLocaleUrl(locale, "playbook/harness-engineering"),
      },
      {
        label: "Loop Engineering",
        href: getRelativeLocaleUrl(locale, "playbook/loop-engineering"),
      },
      {
        label: "Vibe Coding",
        href: getRelativeLocaleUrl(locale, "playbook/vibe-coding"),
      },
    ],
    proofs: [
      {
        label: "Three Frameworks",
        // Blog posts are en-only — always link the en route.
        href: getRelativeLocaleUrl(
          "en",
          "posts/three-frameworks-ai-assisted-product-delivery"
        ),
      },
      {
        label: "AI PM Playbook",
        href: getRelativeLocaleUrl(locale, "playbook"),
      },
    ],
  },
  {
    title: "Industrial & B2B AI",
    description:
      "Enterprise adoption, industrial operations, and B2B product contexts.",
    icon: "Building2",
    proofs: [
      {
        label: "Enterprise Agent Platform",
        href: getRelativeLocaleUrl(
          locale,
          "projects/enterprise-agent-platform"
        ),
      },
    ],
  },
  {
    title: "SEO/GEO Growth",
    description:
      "How generative engines reshape organic growth — experiments in machine-readable content, structured data, and answer-engine optimization.",
    icon: "TrendingUp",
    proofs: [
      {
        label: "Growth Lab",
        href: getRelativeLocaleUrl(locale, "growth-lab"),
      },
    ],
  },
];
---

<Layout
  title={`${config.site.title} — AI Product Manager`}
  ogImage="/og/home.png"
>
  <Header />
  <main
    id="main-content"
    data-layout="index"
    data-home-path={homePath}
    class="app-layout animate-main"
  >
    <!-- Hero -->
    <section class="border-border border-b pt-8 pb-10 sm:pt-12 sm:pb-14">
      <div
        class="flex flex-col gap-6 sm:flex-row sm:items-center sm:justify-between"
      >
        <div class="max-w-2xl">
          <p
            class="border-border text-muted-foreground mb-4 inline-flex items-center gap-2 rounded-full border px-3 py-1 text-xs font-medium"
          >
            <span class="inline-block size-1.5 rounded-full bg-green-500"
            ></span>
            Open to AI PM roles, collaborations, and early-stage ideas —
            <a
              href="#contact"
              class="text-foreground hover:text-accent underline decoration-dashed underline-offset-4"
              >get in touch</a
            >
          </p>
          <h1 class="text-4xl font-bold tracking-tight sm:text-5xl">
            Wenhao Yu
          </h1>
          <div
            class="bg-accent mt-5 h-0.5 w-16 origin-left animate-[slideIn_600ms_ease-out_200ms_forwards]"
            style="transform: scaleX(0);"
          >
          </div>
          <p class="mt-4 text-lg font-medium sm:text-xl">
            AI Product Manager building agentic workflows, ontology-driven
            systems, and AI-native product tools.
          </p>
          <p class="text-muted-foreground mt-3 max-w-2xl">
            I turn ambiguous business problems into structured product concepts,
            interactive prototypes, and reusable delivery systems.
          </p>
          <p class="mt-3 max-w-2xl text-sm font-medium">
            Currently <a
              href={getRelativeLocaleUrl(
                locale,
                "projects/enterprise-agent-platform"
              )}
              class="hover:text-accent underline decoration-dashed underline-offset-4"
              >leading an enterprise agent platform from 0 to 1</a
            > as its product manager.
          </p>
          <p class="mt-3 text-sm">
            <a
              href={getRelativeLocaleUrl(locale, "now")}
              class="text-accent hover:underline"
            >
              → What I'm doing now
            </a>
          </p>
          <p class="text-muted-foreground mt-4 text-sm">Start here →</p>
          <div class="mt-2 flex flex-wrap gap-3">
            <a
              href={getRelativeLocaleUrl(locale, "projects")}
              class="bg-accent text-accent-foreground inline-flex items-center gap-1.5 rounded-md px-5 py-2.5 text-sm font-medium transition-opacity hover:opacity-90"
            >
              View Projects
              <IconArrowRight class="size-4" />
            </a>
            <a
              href="https://wenhaoyu-bryan.github.io/AI-PM-Operating-Playbook/"
              target="_blank"
              rel="noopener noreferrer"
              class="text-muted-foreground hover:text-foreground hover:bg-accent/10 inline-flex items-center gap-1.5 rounded-md border border-transparent px-5 py-2.5 text-sm font-medium transition-colors"
            >
              Open AI PM Operating Playbook ↗
            </a>
          </div>
        </div>
        <img
          src="/profile-avatar.jpg"
          alt="Wenhao Yu - AI Product Manager"
          width="152"
          height="152"
          class="border-border bg-muted/30 size-28 rounded-full border object-cover sm:size-36"
          loading="eager"
          decoding="async"
        />
      </div>
    </section>

    <!-- Featured Projects -->
    <section class="border-border border-b py-10 sm:py-14">
      <h2 class="text-2xl font-semibold tracking-wide">Featured Projects</h2>
      <div class="mt-6 grid gap-4 sm:grid-cols-2">
        {
          projects.map((project, index) => {
            const IconComponent =
              project.icon === "Network"
                ? Network
                : project.icon === "Book"
                  ? Book
                  : project.icon === "Code"
                    ? Code
                    : project.icon === "Activity"
                      ? Activity
                      : project.icon === "Bot"
                        ? Bot
                        : TrendingUp;
            // Shades chosen to meet WCAG AA contrast in both themes:
            // *-700 on the light card bg, *-400 on the dark card bg.
            const statusColor = project.status.startsWith("Public Tool")
              ? "border-blue-500 text-blue-700 dark:text-blue-400"
              : project.status.startsWith("Public")
                ? "border-green-500 text-green-700 dark:text-green-400"
                : project.status.startsWith("Current Work")
                  ? "border-accent text-accent"
                  : "border-orange-500 text-orange-700 dark:text-orange-400";
            return (
              <a
                href={project.href}
                class={`border-border group hover:bg-accent/5 hover:border-accent/30 flex flex-col rounded-lg border p-5 transition-colors ${index === 0 ? "sm:col-span-2" : ""}`}
                {...(project.href.startsWith("http")
                  ? { target: "_blank", rel: "noopener noreferrer" }
                  : {})}
              >
                <div class="flex items-center justify-between gap-2">
                  <IconComponent
                    size={24}
                    strokeWidth={2}
                    class="text-foreground group-hover:text-accent flex-shrink-0 transition-colors"
                  />
                  <span
                    class={`flex flex-shrink-0 items-center gap-1 rounded-full border px-2.5 py-0.5 text-xs whitespace-nowrap ${statusColor}`}
                  >
                    <span class="h-1.5 w-1.5 rounded-full bg-current" />
                    {project.status}
                  </span>
                </div>
                <h3 class="group-hover:text-accent mt-3 text-lg font-medium transition-colors">
                  {project.title}
                </h3>
                <p
                  class={`text-muted-foreground mt-2 text-sm ${index === 0 ? "" : "line-clamp-4"}`}
                >
                  {project.description}
                </p>
              </a>
            );
          })
        }
      </div>
    </section>

    <!-- What I Work On -->
    <section class="border-border border-b py-10 sm:py-14">
      <h2 class="text-2xl font-semibold tracking-wide">What I Work On</h2>
      <div class="mt-6 grid gap-4 sm:grid-cols-2">
        {
          topics.map(topic => {
            const IconComponent =
              topic.icon === "Bot"
                ? Bot
                : topic.icon === "Database"
                  ? Database
                  : topic.icon === "Settings"
                    ? Settings
                    : topic.icon === "TrendingUp"
                      ? TrendingUp
                      : Building2;
            return (
              <div class="border-border hover:bg-accent/5 hover:border-accent/30 group flex flex-col rounded-lg border p-5 transition-colors">
                <div class="flex items-start gap-3">
                  <IconComponent
                    size={24}
                    strokeWidth={2}
                    class="text-foreground group-hover:text-accent mt-0.5 flex-shrink-0 transition-colors"
                  />
                  <div class="min-w-0">
                    <h3 class="font-medium">{topic.title}</h3>
                    <p class="text-muted-foreground mt-1.5 text-sm">
                      {topic.description}
                    </p>
                    {topic.subLinks && (
                      <div class="mt-2.5 flex flex-wrap gap-x-3 gap-y-1 text-sm">
                        {topic.subLinks.map(s => (
                          <a href={s.href} class="text-accent hover:underline">
                            {s.label}
                          </a>
                        ))}
                      </div>
                    )}
                  </div>
                </div>
                <div class="mt-auto flex flex-wrap items-center gap-x-4 gap-y-1 pt-4 pl-9 text-sm">
                  {topic.proofs.map(p => (
                    <a
                      href={p.href}
                      class="text-accent inline-flex items-center gap-1 hover:underline"
                      {...(p.external
                        ? { target: "_blank", rel: "noopener noreferrer" }
                        : {})}
                    >
                      → {p.label}
                      {p.external ? " ↗" : ""}
                    </a>
                  ))}
                </div>
              </div>
            );
          })
        }
      </div>
      <div class="mt-8">
        <h3 class="text-muted-foreground mb-3 text-sm font-medium">Toolbox</h3>
        <div class="flex flex-wrap gap-2">
          {
            [
              "Claude Code",
              "TypeScript",
              "Python",
              "Neo4j",
              "Astro",
              "React",
              "Node.js",
              "Figma",
              "Notion",
              "Obsidian",
            ].map(skill => (
              <span class="border-border bg-muted/30 hover:bg-accent/10 hover:border-accent inline-flex cursor-default items-center gap-1.5 rounded-full border px-3 py-1.5 text-sm transition-colors">
                {skill}
              </span>
            ))
          }
        </div>
        <p class="mt-4 text-sm">
          <a
            href={getRelativeLocaleUrl(locale, "ai-stack")}
            class="text-accent hover:underline"
          >
            How I orchestrate these tools → My AI Stack
          </a>
        </p>
      </div>
    </section>

    <!-- Latest Writing -->
    {
      recentPosts.length > 0 && (
        <section class="border-border border-b py-10 sm:py-14">
          <h2 class="text-2xl font-semibold tracking-wide">
            {t.home.recentPosts}
          </h2>
          <ul class="mt-4">
            {recentPosts.slice(0, 3).map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
          <div class="mt-6">
            <LinkButton href={getRelativeLocaleUrl(locale, "posts")}>
              {t.home.allPosts}
              <IconArrowRight class="inline-block rtl:-rotate-180" />
            </LinkButton>
          </div>
        </section>
      )
    }

    <!-- Contact -->
    <section id="contact" class="py-10 sm:py-14">
      <h2 class="text-2xl font-semibold tracking-wide">Get in Touch</h2>
      <p class="text-muted-foreground mt-2 max-w-xl">
        Interested in AI product collaboration, ontology-driven systems, or
        growth experiments? I'm happy to talk — whether you're hiring, building,
        or just comparing notes.
      </p>
      <div class="mt-5 max-w-xl">
        <ContactRow locale={locale} />
      </div>
      <div class="mt-5 max-w-xl">
        <AskAI locale={locale} />
      </div>
      <p class="text-muted-foreground mt-5 text-sm">
        Prefer another channel? X and Medium are in the footer below.
      </p>
    </section>
  </main>
  <Footer />
</Layout>

<script>
  import "@/scripts/homeReveal";

  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset;
    const baseRoot = import.meta.env.BASE_URL.replace(/\/?$/, "/");
    if (indexLayout?.layout) {
      sessionStorage.setItem("backUrl", indexLayout.homePath ?? baseRoot);
    }
  });
</script>
