---
import { getCollection } from "astro:content";
import { getRelativeLocaleUrl } from "astro:i18n";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Card from "@/components/Card.astro";
import LinkButton from "@/components/LinkButton.astro";
import { getSortedPosts } from "@/utils/getSortedPosts";
import { useTranslations } from "@/i18n";
import config from "@/config";
import { Network, Book, Code, TrendingUp, Bot, Database, Settings, RefreshCw, Wand2, Building2, Mail, Github, Linkedin, Twitter, BookOpen } from "lucide-astro";

const locale = Astro.currentLocale ?? config.site.lang;
const t = useTranslations(locale);

const posts = await getCollection("posts");
const sortedPosts = getSortedPosts(posts);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);
const homePath = getRelativeLocaleUrl(locale, "");

const projects = [
  {
    title: "Prompt-to-Ontology",
    description:
      "A public experiment turning messy requirements and business concepts into ontology assets: entities, relationships, constraints, and action-ready knowledge graphs for enterprise AI systems.",
    status: "Public",
    icon: "Network",
    href: getRelativeLocaleUrl(locale, "projects/prompt-to-ontology"),
  },
  {
    title: "AI PM Operating Playbook",
    description:
      "A methodology-driven toolkit that turns ambiguous AI product ideas into structured product briefs, workflow specifications, evaluation plans, and coding-agent handoff materials.",
    status: "Public Tool",
    icon: "Book",
    href: "https://wenhaoyu-bryan.github.io/AI-PM-Operating-Playbook/",
  },
  {
    title: "Vibe Coding Prototype Lab",
    description:
      "A public lab showing how PM-led LLM pair programming can turn ambiguous ideas into prototypes, specs, and reusable product workflows.",
    status: "Public",
    icon: "Code",
    href: getRelativeLocaleUrl(locale, "projects/vibe-coding-prototype-lab"),
  },
  {
    title: "SEO/GEO Growth Experiments",
    description:
      "Experiments on content systems, B2B websites, and AI-search-aware growth loops — connecting SEO fundamentals with GEO visibility.",
    status: "Ongoing",
    icon: "TrendingUp",
    href: getRelativeLocaleUrl(locale, "growth-lab"),
  },
];

const topics = [
  {
    title: "Agentic Workflows",
    description: "Designing agent systems with tools, memory, and governance.",
    icon: "Bot",
  },
  {
    title: "Ontology-Driven AI Products",
    description:
      "Using knowledge graphs and structured ontologies to make enterprise AI reliable.",
    icon: "Database",
  },
  {
    title: "Harness Engineering",
    description:
      "Designing the context, tools, constraints, and feedback systems that guide AI coding agents.",
    icon: "Settings",
  },
  {
    title: "Loop Engineering",
    description:
      "Designing the feedback loops through which AI products, teams, and delivery artifacts improve over iterations.",
    icon: "RefreshCw",
  },
  {
    title: "Vibe Coding for PMs",
    description:
      "PM-led, coding-agent-assisted prototyping for early discovery and workflow validation.",
    icon: "Wand2",
  },
  {
    title: "Industrial & B2B AI",
    description:
      "Enterprise AI adoption, industrial operations, and B2B product contexts.",
    icon: "Building2",
  },
];
---

<Layout>
  <Header />
  <main
    id="main-content"
    data-layout="index"
    data-home-path={homePath}
    class="app-layout"
  >
    <!-- Hero -->
    <section class="border-border border-b pt-8 pb-10 sm:pt-12 sm:pb-14">
      <div class="h-0.5 w-16 bg-accent animate-[slideIn_600ms_ease-out_200ms_forwards] origin-left" style="transform: scaleX(0);"></div>
      <p class="text-lg font-medium sm:text-xl mt-4">
        AI Product Manager building agentic workflows, ontology-driven systems,
        and AI-native product tools.
      </p>
      <p class="text-muted-foreground mt-3 max-w-2xl">
        I turn ambiguous business problems into structured product concepts,
        interactive prototypes, and reusable delivery systems.
      </p>
      <p class="text-muted-foreground text-sm mt-4">Start here →</p>
      <div class="mt-2 flex flex-wrap gap-3">
        <a
          href={getRelativeLocaleUrl(locale, "projects")}
          class="bg-accent text-accent-foreground inline-flex items-center gap-1.5 rounded-md px-5 py-2.5 text-sm font-medium transition-all hover:scale-105 hover:shadow-[0_2px_8px_rgba(0,0,0,0.08)] dark:hover:shadow-[0_2px_8px_rgba(0,0,0,0.3)]"
        >
          View Projects
          <IconArrowRight class="size-4" />
        </a>
        <a
          href="https://wenhaoyu-bryan.github.io/AI-PM-Operating-Playbook/"
          target="_blank"
          rel="noopener noreferrer"
          class="border-border text-foreground hover:bg-accent/10 inline-flex items-center gap-1.5 rounded-md border px-5 py-2.5 text-sm font-medium transition-colors"
        >
          Open AI PM Operating Playbook ↗
        </a>
        <a
          href={getRelativeLocaleUrl(locale, "posts")}
          class="border-border text-foreground hover:bg-accent/10 inline-flex items-center gap-1.5 rounded-md border px-5 py-2.5 text-sm font-medium transition-colors"
        >
          Read My Writing
        </a>
      </div>
    </section>

    <!-- Featured Projects -->
    <section class="border-border border-b py-10 sm:py-14">
      <h2 class="text-2xl font-semibold tracking-wide">Featured Projects</h2>
      <div class="mt-6 grid gap-4 sm:grid-cols-2">
        {
          projects.map(project => {
            const IconComponent = project.icon === "Network" ? Network :
                                  project.icon === "Book" ? Book :
                                  project.icon === "Code" ? Code : TrendingUp;
            const statusColor = project.status === "Public" ? "border-green-500 text-green-600" :
                               project.status === "Public Tool" ? "border-blue-500 text-blue-600" :
                               "border-orange-500 text-orange-600";
            return (
              <a
                href={project.href}
                class="border-border group hover:bg-accent/5 hover:border-accent hover:-translate-y-1 hover:shadow-[0_4px_12px_rgba(0,0,0,0.06)] dark:hover:shadow-[0_4px_12px_rgba(0,0,0,0.3)] rounded-lg border p-5 transition-all duration-200"
                {...(project.href.startsWith("http")
                  ? { target: "_blank", rel: "noopener noreferrer" }
                  : {})}
              >
                <div class="flex items-start gap-3">
                  <IconComponent size={24} strokeWidth={2} class="text-foreground group-hover:text-accent transition-colors flex-shrink-0 mt-0.5" />
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center justify-between gap-2">
                      <h3 class="group-hover:text-accent text-lg font-medium transition-colors">
                        {project.title}
                      </h3>
                      <span class={`rounded-full border px-2.5 py-0.5 text-xs flex items-center gap-1 flex-shrink-0 ${statusColor}`}>
                        <span class="w-1.5 h-1.5 rounded-full bg-current"></span>
                        {project.status}
                      </span>
                    </div>
                    <p class="text-muted-foreground mt-2 text-sm">
                      {project.description}
                    </p>
                  </div>
                </div>
              </a>
            );
          })
        }
      </div>
    </section>

    <!-- Featured Content -->
    <section class="border-border border-b py-10 sm:py-14">
      <h2 class="text-2xl font-semibold tracking-wide">Featured</h2>
      <p class="text-muted-foreground mt-2 text-sm">
        Start here — the strongest signals from my work.
      </p>
      <div class="mt-6 flex flex-wrap gap-3">
        <a
          href={getRelativeLocaleUrl(locale, "posts/building-ontology-os")}
          class="border-border text-foreground hover:bg-accent/10 inline-flex items-center gap-1.5 rounded-md border px-4 py-2 text-sm font-medium transition-colors"
        >
          Building Ontology OS
        </a>
        <a
          href={getRelativeLocaleUrl(locale, "playbook/harness-engineering")}
          class="border-border text-foreground hover:bg-accent/10 inline-flex items-center gap-1.5 rounded-md border px-4 py-2 text-sm font-medium transition-colors"
        >
          Harness Engineering
        </a>
        <a
          href={getRelativeLocaleUrl(locale, "playbook/ai-native-prd")}
          class="border-border text-foreground hover:bg-accent/10 inline-flex items-center gap-1.5 rounded-md border px-4 py-2 text-sm font-medium transition-colors"
        >
          AI-Native PRD
        </a>
        <a
          href={getRelativeLocaleUrl(locale, "playbook/loop-engineering")}
          class="border-border text-foreground hover:bg-accent/10 inline-flex items-center gap-1.5 rounded-md border px-4 py-2 text-sm font-medium transition-colors"
        >
          Loop Engineering
        </a>
        <a
          href={getRelativeLocaleUrl(
            locale,
            "projects/vibe-coding-prototype-lab"
          )}
          class="border-border text-foreground hover:bg-accent/10 inline-flex items-center gap-1.5 rounded-md border px-4 py-2 text-sm font-medium transition-colors"
        >
          Vibe Coding Prototype Lab
        </a>
        <a
          href={getRelativeLocaleUrl(locale, "playbook/seo-to-geo")}
          class="border-border text-foreground hover:bg-accent/10 inline-flex items-center gap-1.5 rounded-md border px-4 py-2 text-sm font-medium transition-colors"
        >
          SEO to GEO
        </a>
        <a
          href={getRelativeLocaleUrl(locale, "projects/prompt-to-ontology")}
          class="border-border text-foreground hover:bg-accent/10 inline-flex items-center gap-1.5 rounded-md border px-4 py-2 text-sm font-medium transition-colors"
        >
          Prompt-to-Ontology
        </a>
      </div>
    </section>

    <!-- What I Work On -->
    <section class="border-border border-b py-10 sm:py-14">
      <h2 class="text-2xl font-semibold tracking-wide">What I Work On</h2>
      <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {
          topics.map(topic => {
            const IconComponent = topic.icon === "Bot" ? Bot :
                                  topic.icon === "Database" ? Database :
                                  topic.icon === "Settings" ? Settings :
                                  topic.icon === "RefreshCw" ? RefreshCw :
                                  topic.icon === "Wand2" ? Wand2 : Building2;
            return (
              <div class="border-border rounded-lg border p-5 hover:bg-accent/5 hover:border-accent/30 transition-all duration-200 group">
                <div class="flex items-start gap-3">
                  <IconComponent size={24} strokeWidth={2} class="text-foreground group-hover:text-accent transition-colors flex-shrink-0 mt-0.5" />
                  <div>
                    <h3 class="font-medium">{topic.title}</h3>
                    <p class="text-muted-foreground mt-1.5 text-sm">
                      {topic.description}
                    </p>
                  </div>
                </div>
              </div>
            );
          })
        }
      </div>
    </section>

    <!-- Skills & Tools -->
    <section class="border-border border-b py-10 sm:py-14">
      <h2 class="text-2xl font-semibold tracking-wide">Skills & Tools</h2>
      <div class="mt-6 space-y-6">
        <!-- Product Skills -->
        <div>
          <h3 class="text-sm font-medium text-muted-foreground mb-3">Product Skills</h3>
          <div class="flex flex-wrap gap-2">
            {["Ontology Design", "Agentic Workflows", "PRD Writing", "Vibe Coding", "Loop Engineering", "Harness Engineering"].map(skill => (
              <span class="inline-flex items-center gap-1.5 px-3 py-1.5 text-sm border border-border rounded-full bg-muted/30 hover:bg-accent/10 hover:border-accent hover:scale-105 transition-all cursor-default">
                {skill}
              </span>
            ))}
          </div>
        </div>
        <!-- Technical Stack -->
        <div>
          <h3 class="text-sm font-medium text-muted-foreground mb-3">Technical Stack</h3>
          <div class="flex flex-wrap gap-2">
            {["JavaScript", "TypeScript", "Python", "Neo4j", "Astro", "React", "Node.js"].map(skill => (
              <span class="inline-flex items-center gap-1.5 px-3 py-1.5 text-sm border border-border rounded-full bg-muted/30 hover:bg-accent/10 hover:border-accent hover:scale-105 transition-all cursor-default">
                {skill}
              </span>
            ))}
          </div>
        </div>
        <!-- Tools & Platforms -->
        <div>
          <h3 class="text-sm font-medium text-muted-foreground mb-3">Tools & Platforms</h3>
          <div class="flex flex-wrap gap-2">
            {["Claude Code", "GitHub", "Figma", "Notion", "Obsidian", "VS Code"].map(skill => (
              <span class="inline-flex items-center gap-1.5 px-3 py-1.5 text-sm border border-border rounded-full bg-muted/30 hover:bg-accent/10 hover:border-accent hover:scale-105 transition-all cursor-default">
                {skill}
              </span>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Latest Writing -->
    {
      recentPosts.length > 0 && (
        <section class="py-10 sm:py-14">
          <h2 class="text-2xl font-semibold tracking-wide">
            {t.home.recentPosts}
          </h2>
          <ul class="mt-4">
            {recentPosts.slice(0, 3).map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
          <div class="mt-6">
            <LinkButton href={getRelativeLocaleUrl(locale, "posts")}>
              {t.home.allPosts}
              <IconArrowRight class="inline-block rtl:-rotate-180" />
            </LinkButton>
          </div>
        </section>
      )
    }
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset;
    const baseRoot = import.meta.env.BASE_URL.replace(/\/?$/, "/");
    if (indexLayout?.layout) {
      sessionStorage.setItem("backUrl", indexLayout.homePath ?? baseRoot);
    }
  });
</script>
