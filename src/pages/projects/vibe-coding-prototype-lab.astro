---
import { getRelativeLocaleUrl } from "astro:i18n";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Main from "@/components/Main.astro";
import Footer from "@/components/Footer.astro";
import FlowDiagram from "@/components/FlowDiagram.astro";
import config from "@/config";

const workflowSteps = [
  { label: "Product Intent", note: "define the why" },
  { label: "Constraints & Non-Goals", note: "scope the box" },
  { label: "Working Prototype", note: "generate small", emphasis: true },
  { label: "Behavior Review", note: "not just code" },
  { label: "Reusable Patterns", note: "refactor" },
  { label: "Playbook", note: "document learning", emphasis: true },
];

const snapshot = [
  { label: "Role", value: "Product Manager driving PM-led prototyping" },
  { label: "Type", value: "Ongoing public lab" },
  { label: "Tools", value: "Claude Code · Cursor · LLM pair programming" },
  { label: "Status", value: "Active — new experiments added over time" },
];
---

<Layout
  title={`Vibe Coding Prototype Lab | ${config.site.title}`}
  description="A public lab for how AI Product Managers use Claude Code, Cursor, and LLM pair programming to turn product ideas into prototypes, specs, and reusable workflows."
>
  <Header />
  <Breadcrumb />

  <Main pageTitle="Vibe Coding Prototype Lab" class="app-prose">
    <p class="text-muted-foreground text-sm">
      <a
        href={getRelativeLocaleUrl("zh", "projects/vibe-coding-prototype-lab")}
        class="text-accent hover:underline"
      >
        阅读中文版
      </a>
    </p>

    <p class="text-muted-foreground text-lg">
      A public lab for how AI Product Managers can use Claude Code, Cursor, and
      LLM pair programming to turn product ideas into prototypes, specs, and
      reusable workflows.
    </p>

    <div class="border-border mt-4 flex flex-wrap gap-2">
      <span class="rounded-full border px-3 py-1 text-xs font-medium">
        Claude Code
      </span>
      <span class="rounded-full border px-3 py-1 text-xs font-medium">
        Cursor
      </span>
      <span class="rounded-full border px-3 py-1 text-xs font-medium">
        LLM Pair Programming
      </span>
      <span class="rounded-full border px-3 py-1 text-xs font-medium">
        Prototyping
      </span>
    </div>

    <div
      class="border-border bg-border mt-6 grid gap-px overflow-hidden rounded-lg border sm:grid-cols-2"
    >
      {
        snapshot.map(item => (
          <div class="bg-background p-4">
            <p class="text-muted-foreground text-xs font-medium tracking-wide uppercase">
              {item.label}
            </p>
            <p class="mt-1 text-sm">{item.value}</p>
          </div>
        ))
      }
    </div>

    <h2 class="mt-8 text-xl font-semibold">Why This Matters</h2>
    <p>
      AI PMs increasingly need to move from writing abstract requirements to
      shaping working product behavior. Vibe coding gives PMs a way to test
      product logic, interaction flows, and technical assumptions before asking
      engineering teams to commit full resources.
    </p>

    <h2 class="mt-6 text-xl font-semibold">What I Use It For</h2>
    <ul class="mt-2 space-y-2">
      <li>Turning rough product ideas into clickable prototypes</li>
      <li>Converting PRDs into implementation-ready specs</li>
      <li>Exploring architecture boundaries</li>
      <li>Testing agent workflows and tool-use logic</li>
      <li>
        Building sanitized public experiments from private product learning
      </li>
    </ul>

    <h2 class="mt-6 text-xl font-semibold">My Workflow</h2>
    <FlowDiagram
      steps={workflowSteps}
      caption="Each cycle ends in a documented, reusable pattern — the prototype is the byproduct, the playbook is the asset."
    />

    <h2 class="mt-6 text-xl font-semibold">Outcomes & Signals</h2>
    <ul class="mt-2 space-y-2">
      <li>
        <a
          href={getRelativeLocaleUrl(
            config.site.lang,
            "projects/prompt-to-ontology"
          )}
          class="text-accent hover:underline">Prompt-to-Ontology</a
        > — a full-stack ontology prototype built end-to-end with this workflow.
      </li>
      <li>
        The <a
          href="https://wenhaoyu-bryan.github.io/AI-PM-Operating-Playbook/"
          class="text-accent hover:underline"
          target="_blank"
          rel="noopener noreferrer">AI PM Operating Playbook</a
        > — an interactive tool suite, itself vibe-coded.
      </li>
      <li>
        This website — designed, built, and iterated through PM-led LLM pair
        programming on Astro.
      </li>
      <li>
        The workflow is documented as reusable methodology in the
        <a
          href={getRelativeLocaleUrl(config.site.lang, "playbook/vibe-coding")}
          class="text-accent hover:underline">Vibe Coding playbook</a
        >.
      </li>
    </ul>

    <h2 class="mt-6 text-xl font-semibold">What This Is Not</h2>
    <p>
      This is not a replacement for professional engineering. It is a way for
      PMs to clarify product behavior, reduce ambiguity, and collaborate with
      engineering from a stronger starting point. Some company-related work
      cannot be shared due to data and permission constraints — the public lab
      contains sanitized experiments and reusable workflows.
    </p>

    <h2 class="mt-6 text-xl font-semibold">Public Experiments</h2>
    <ul class="mt-2 space-y-2">
      <li>
        <a
          href={getRelativeLocaleUrl(
            config.site.lang,
            "projects/prompt-to-ontology"
          )}
          class="text-accent hover:underline"
        >
          Prompt-to-Ontology
        </a> — ontology-driven enterprise AI prototype
      </li>
      <li>
        <a
          href={getRelativeLocaleUrl(config.site.lang, "playbook")}
          class="text-accent hover:underline"
        >
          AI PM Operating Playbook
        </a> — frameworks and workflows
      </li>
      <li>Future sanitized prototypes</li>
    </ul>

    <div class="mt-6 flex flex-wrap gap-3">
      <a
        href="https://github.com/wenhaoyu-bryan/prompt-to-ontology"
        class="bg-accent text-accent-foreground inline-flex items-center gap-1.5 rounded-md px-5 py-2.5 text-sm font-medium transition-opacity hover:opacity-90"
        target="_blank"
        rel="noopener noreferrer"
      >
        View Prompt-to-Ontology on GitHub
      </a>
      <a
        href={getRelativeLocaleUrl(config.site.lang, "playbook")}
        class="border-border text-foreground hover:bg-accent/10 inline-flex items-center gap-1.5 rounded-md border px-5 py-2.5 text-sm font-medium transition-colors"
      >
        Read the Playbook
      </a>
      <a
        href="https://github.com/wenhaoyu-bryan"
        class="border-border text-foreground hover:bg-accent/10 inline-flex items-center gap-1.5 rounded-md border px-5 py-2.5 text-sm font-medium transition-colors"
        target="_blank"
        rel="noopener noreferrer"
      >
        GitHub Profile
      </a>
    </div>
  </Main>

  <Footer />
</Layout>
