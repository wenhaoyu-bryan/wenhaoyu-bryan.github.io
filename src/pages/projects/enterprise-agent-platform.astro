---
import { getRelativeLocaleUrl } from "astro:i18n";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Main from "@/components/Main.astro";
import Footer from "@/components/Footer.astro";
import FlowDiagram from "@/components/FlowDiagram.astro";
import config from "@/config";

const locale = Astro.currentLocale ?? config.site.lang;

const snapshot = [
  { label: "Role", value: "Product Manager (0 → 1 lead)" },
  {
    label: "Domain",
    value: "Advanced manufacturing (semiconductor & adjacent)",
  },
  { label: "Status", value: "Current Work · in development" },
  {
    label: "Confidentiality",
    value: "Methodology described · internals abstracted",
  },
];

// Abstracted shape of the platform — no internal system names. Each step maps
// to a capability described in the approved content below.
const architectureSteps = [
  {
    label: "Business Workspace + Developer Console",
    note: "dual-mode",
    emphasis: true,
  },
  {
    label: "Agent Configuration",
    note: "prompt · model · knowledge · tools · skills",
  },
  { label: "Skill Lifecycle", note: "co-create · edit · version · publish" },
  {
    label: "Governance Layer",
    note: "sandbox · approval · audit",
    emphasis: true,
  },
  { label: "Automation Triggers", note: "webhook · queue · schedule" },
  { label: "Enterprise Skill Center", note: "expertise compounds" },
];
---

<Layout
  title={`Enterprise Agent Platform (0 → 1) — Current Work — ${config.site.title}`}
  description="Leading an enterprise agent platform from 0 to 1 in advanced manufacturing — dual-mode design, governed reusable skills, and multi-agent work in progress."
  ogImage="/og/enterprise-agent-platform.png"
>
  <Header />
  <Breadcrumb />

  <Main pageTitle="Enterprise Agent Platform (0 → 1)" class="app-prose">
    <p class="text-muted-foreground text-sm">
      <a
        href={getRelativeLocaleUrl("zh", "projects/enterprise-agent-platform")}
        class="text-accent hover:underline"
      >
        阅读中文版
      </a>
    </p>

    <p class="text-muted-foreground text-lg">
      An enterprise agent platform for advanced manufacturing (semiconductor and
      adjacent process industries) that turns expert knowledge and business
      workflows into governed, reusable AI agents — "digital employees." I lead
      it from 0 to 1 as its product manager. This is current, ongoing work, so
      the page describes methodology and capabilities while keeping internal
      systems, data, and identities abstracted.
    </p>

    <div class="border-border mt-4 flex flex-wrap gap-2">
      <span
        class="text-foreground rounded-full border px-3 py-1 text-xs font-medium"
      >
        Current Work
      </span>
      <span
        class="text-foreground rounded-full border px-3 py-1 text-xs font-medium"
      >
        Agent Platform
      </span>
      <span
        class="text-foreground rounded-full border px-3 py-1 text-xs font-medium"
      >
        Enterprise AI
      </span>
      <span
        class="text-foreground rounded-full border px-3 py-1 text-xs font-medium"
      >
        0 → 1
      </span>
      <span
        class="text-foreground rounded-full border px-3 py-1 text-xs font-medium"
      >
        Governance by Design
      </span>
    </div>

    <div
      class="border-border bg-border mt-6 grid gap-px overflow-hidden rounded-lg border sm:grid-cols-2"
    >
      {
        snapshot.map(item => (
          <div class="bg-background p-4">
            <p class="text-muted-foreground text-xs font-medium tracking-wide uppercase">
              {item.label}
            </p>
            <p class="mt-1 text-sm">{item.value}</p>
          </div>
        ))
      }
    </div>

    <div
      class="border-border bg-muted/30 text-muted-foreground mt-6 rounded-lg border p-4 text-sm"
    >
      <strong class="text-foreground">A note on confidentiality.</strong> This is
      real, ongoing product work in an enterprise setting. Methodology and capabilities
      are described here; internal systems, data, and identities are abstracted. The
      platform is still in development, so there are no reported outcome metrics —
      I don't publish numbers I can't share.
    </div>

    <!-- ─────────────────────────  1. WHAT IT IS  ───────────────────────── -->
    <h2 class="mt-8 text-xl font-semibold">What it is</h2>
    <p>
      The platform gives an industrial organization a way to turn deep domain
      expertise and existing business workflows into agents that can be reused,
      governed, and shared — instead of knowledge that lives only in people and
      spreadsheets. It has a dual-mode design. A <strong
        >business workspace</strong
      > is where frontline operators and engineers converse with agents, mount the
      skills they need, and track their tasks. A <strong
        >developer console</strong
      > is where builders configure agents end to end. The two modes share the same
      underlying assets, so what a builder ships becomes something an operator can
      immediately use.
    </p>

    <!-- ─────────────────────────  2. MY ROLE  ───────────────────────── -->
    <h2 class="mt-8 text-xl font-semibold">My role</h2>
    <p>
      I lead this platform from 0 to 1 as its product manager: ideation, PRDs,
      competitor analysis, customer feedback loops, and vibe-coded prototypes
      that become the engineering blueprint. Rather than hand engineering a
      static spec, I use PM-led, coding-agent-assisted prototyping to turn key
      flows into working prototypes — a clickable prototype removes ambiguity
      from the spec and becomes the reference the team builds against.
      <a
        href={getRelativeLocaleUrl(locale, "playbook/vibe-coding")}
        class="text-accent hover:underline">Vibe Coding →</a
      >
    </p>

    <!-- ─────────────────────────  3. CAPABILITIES  ───────────────────────── -->
    <h2 class="mt-8 text-xl font-semibold">Platform capabilities</h2>

    <h3 class="mt-6 text-lg font-medium">Agent configuration</h3>
    <p>Each agent is assembled from a set of composable pieces:</p>
    <ul class="mt-2 space-y-2">
      <li>a system prompt, model selection, and sampling parameters;</li>
      <li>knowledge bases with hybrid retrieval;</li>
      <li>
        enterprise terminology dictionaries, so model output stays consistent
        with company vocabulary;
      </li>
      <li>structured datasets the agent can query directly;</li>
      <li>
        tool assets — functions, APIs, and standard protocols — callable during
        reasoning;
      </li>
      <li>and versioned skills.</li>
    </ul>
    <p class="mt-3">
      Two capabilities are independent per-agent toggles: a clarifying-question
      mode that asks for more when user input is insufficient, and web search.
    </p>

    <h3 class="mt-6 text-lg font-medium">Skill lifecycle</h3>
    <p>Skills can be created three ways:</p>
    <ul class="mt-2 space-y-2">
      <li>
        <strong>AI co-creation</strong> — describe a need in natural language; the
        system asks clarifying questions, then generates the code, configuration,
        and documentation, visualizing the execution logic as a step-by-step blueprint.
      </li>
      <li>
        <strong>Blank-skill authoring</strong> — build in a built-in editor with a
        Copilot-style assistant that proposes changes as apply-able diffs.
      </li>
      <li><strong>Package import</strong> — bring in an existing skill.</li>
    </ul>
    <p class="mt-3">
      Every skill carries versions, permissions (owner / collaborator / user;
      use / edit), and release notes with change-type tags and impact scope.
      Published skills go into a shared enterprise skill center organized by
      official / department / personal scope — so expertise compounds across the
      organization instead of leaving with individuals.
    </p>

    <!-- ─────────────────────────  4. GOVERNANCE  ───────────────────────── -->
    <h2 class="mt-8 text-xl font-semibold">Governance by design</h2>
    <p>
      In an industrial setting, a confidently wrong automated action is
      expensive, so governance is designed in rather than bolted on. The
      controls:
    </p>
    <ul class="mt-2 space-y-2">
      <li>dev / prod sandbox isolation;</li>
      <li>simulated execution before release;</li>
      <li>
        per-skill human-confirmation gates — "require approval before
        execution";
      </li>
      <li>high-risk capability toggles;</li>
      <li>approval queues;</li>
      <li>
        and a task center that audits every automated run with status tracking
        (completed / running / awaiting approval / error).
      </li>
    </ul>
    <p class="mt-3">
      The principle underneath all of it: AI-generated capabilities enter a
      verifiable, traceable environment before they can touch real business
      systems. This is what makes adoption possible at all — experts will try a
      system that cannot act behind their back long before they'll try one that
      can.
    </p>

    <!-- ─────────────────────────  5. AUTOMATION  ───────────────────────── -->
    <h2 class="mt-8 text-xl font-semibold">Automation &amp; integration</h2>
    <p>Three trigger types connect agents to live operations:</p>
    <ul class="mt-2 space-y-2">
      <li>
        <strong>Webhook callbacks</strong> with auth tokens and data-mapping templates;
      </li>
      <li>
        <strong>Message-queue events</strong>, where high-confidence matches
        auto-process and low-confidence ones route to human approval;
      </li>
      <li>
        <strong>Scheduled jobs</strong> producing recurring analyses and reports.
      </li>
    </ul>
    <p class="mt-3">
      Agents can be embedded in third-party systems via iframe or published as
      APIs with managed keys and expiry policies. A model-management layer lets
      the platform swap and govern multiple LLMs (chat, rerank, embedding)
      behind one interface.
    </p>

    <FlowDiagram
      steps={architectureSteps}
      caption="The shape of the platform, abstracted: a dual-mode surface over configurable agents and a skill lifecycle, gated by a governance layer before automation triggers ever run — with published skills feeding back into a shared enterprise skill center."
    />

    <!-- ─────────────────────────  6. IN PROGRESS  ───────────────────────── -->
    <h2 class="mt-8 text-xl font-semibold">
      In progress: multi-agent architecture
    </h2>
    <p>
      Two capabilities are currently in development. The first is multi-agent
      <strong>communication sessions</strong> — agents sharing context within a session.
      The second is an <strong>orchestrator–worker</strong> (hierarchical lead / subordinate)
      structure, where a lead agent decomposes a task and delegates to specialized
      subordinate agents. The same governance surface — approval gates and auditability
      — extends to inter-agent delegation, so the reliability story holds even as
      agents start handing work to one another.
    </p>

    <!-- ─────────────────────────  7. FRAMEWORKS  ───────────────────────── -->
    <h2 class="mt-8 text-xl font-semibold">
      How this connects to my frameworks
    </h2>
    <p>
      The methods I write about in the playbook are not post-hoc theory — they
      are how this platform actually gets built. <a
        href={getRelativeLocaleUrl(locale, "playbook/harness-engineering")}
        class="text-accent hover:underline">Harness engineering</a
      > is how agent output is made trustworthy enough for a domain expert to accept:
      defining the context, tools, constraints, and acceptance criteria an agent operates
      within. <a
        href={getRelativeLocaleUrl(locale, "playbook/loop-engineering")}
        class="text-accent hover:underline">Loop engineering</a
      > is how expert feedback flows back into configuration and constraints instead
      of living in someone's head. And <a
        href={getRelativeLocaleUrl(locale, "playbook/vibe-coding")}
        class="text-accent hover:underline">vibe coding</a
      > is how a prototype becomes the blueprint. The grounded-configuration approach
      also connects to the ontology work elsewhere on this site — the more the system's
      knowledge is structured and explicit, the less it has to guess.
      <a
        href={getRelativeLocaleUrl(locale, "projects/prompt-to-ontology")}
        class="text-accent hover:underline">See Prompt-to-Ontology →</a
      >
    </p>

    <div
      class="border-border bg-muted/30 mt-8 flex flex-col gap-3 rounded-lg border p-5 sm:flex-row sm:items-center sm:justify-between"
    >
      <div>
        <p class="font-medium">The methodology behind this, in the open</p>
        <p class="text-muted-foreground text-sm">
          The frameworks referenced above are written up in full in the
          playbook.
        </p>
      </div>
      <a
        href={getRelativeLocaleUrl(locale, "playbook")}
        class="bg-accent text-accent-foreground inline-flex shrink-0 items-center gap-1.5 rounded-md px-5 py-2.5 text-sm font-medium transition-opacity hover:opacity-90"
      >
        Read the Playbook &rarr;
      </a>
    </div>

    <div class="border-border mt-8 rounded-lg border p-6">
      <h2 class="text-lg font-semibold">Related</h2>
      <div class="mt-3 flex flex-wrap gap-3">
        <a
          href={getRelativeLocaleUrl(locale, "projects/prompt-to-ontology")}
          class="text-accent hover:underline"
        >
          Prompt-to-Ontology
        </a>
        <a
          href={getRelativeLocaleUrl(locale, "playbook/harness-engineering")}
          class="text-accent hover:underline"
        >
          Harness Engineering
        </a>
        <a
          href={getRelativeLocaleUrl(locale, "playbook/vibe-coding")}
          class="text-accent hover:underline"
        >
          Vibe Coding
        </a>
        <a
          href="https://wenhaoyu-bryan.github.io/agent-anatomy/"
          class="text-accent hover:underline"
          target="_blank"
          rel="noopener noreferrer"
        >
          Agent Anatomy ↗
        </a>
      </div>
    </div>
  </Main>

  <Footer />
</Layout>
