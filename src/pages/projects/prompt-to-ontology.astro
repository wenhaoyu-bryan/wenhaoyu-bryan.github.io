---
import { getRelativeLocaleUrl } from "astro:i18n";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Main from "@/components/Main.astro";
import Footer from "@/components/Footer.astro";
import FlowDiagram from "@/components/FlowDiagram.astro";
import ScreenshotGallery from "@/components/ScreenshotGallery.astro";
import type { Shot } from "@/components/ScreenshotGallery.astro";
import config from "@/config";

import dashboard from "@/assets/projects/prompt-to-ontology/dashboard.png";
import dataPipeline from "@/assets/projects/prompt-to-ontology/data-pipeline.png";
import ontologyManager from "@/assets/projects/prompt-to-ontology/ontology-manager.png";
import graph from "@/assets/projects/prompt-to-ontology/graph.png";
import analystAgent from "@/assets/projects/prompt-to-ontology/analyst-agent.png";
import reviewQueue from "@/assets/projects/prompt-to-ontology/review-queue.png";

const walkthrough: Shot[] = [
  {
    src: dashboard,
    alt: "Operational ontology runtime dashboard",
    caption:
      "Operational runtime — 46 ontology objects, 116 relations, 5 risk rules, 324 review items live.",
  },
  {
    src: dataPipeline,
    alt: "Data pipeline: select, profile, map, validate, import",
    caption:
      "Data pipeline — profile raw CSV, map fields to ontology types, and stage reviewable import plans.",
  },
  {
    src: ontologyManager,
    alt: "Ontology schema manager with object types, relations, rules, actions",
    caption:
      "Ontology schema — 6 object types, relationship types, validation rules, and action definitions.",
  },
  {
    src: graph,
    alt: "Interactive knowledge graph explorer",
    caption:
      "Graph explorer — the inferred knowledge graph rendered as typed objects and relationships.",
  },
  {
    src: analystAgent,
    alt: "Analyst agent answering questions via ontology tools",
    caption:
      "Analyst agent — answers by calling ontology tools, not guessing; proposes reviewable actions only.",
  },
  {
    src: reviewQueue,
    alt: "Human-in-the-loop review queue",
    caption:
      "Review queue — low-confidence candidates and agent suggestions wait for human approval before write.",
  },
];

const architectureSteps = [
  { label: "Raw CSV / Requirements", note: "messy input" },
  { label: "LLM Schema Inference", note: "reasoning layer", emphasis: true },
  { label: "Ontology Schema", note: "entities · relations · constraints" },
  { label: "Neo4j Graph", note: "data source" },
  { label: "NetworkX", note: "compute engine" },
  { label: "ReAct Agent", note: "queries + suggestions", emphasis: true },
  { label: "Human-in-the-Loop", note: "approved actions" },
];

const snapshot = [
  { label: "Role", value: "Product Manager & solo builder" },
  { label: "Type", value: "Public case study / working prototype" },
  { label: "Stack", value: "Neo4j · NetworkX · LLM · ReAct Agent" },
  { label: "Status", value: "Public repo, actively extended" },
];
---

<Layout
  title={`Prompt-to-Ontology | ${config.site.title}`}
  description="Case study: turning messy requirements and raw CSV data into an operational knowledge graph with an agent layer — ontology schema inference, Neo4j, and human-in-the-loop actions."
>
  <Header />
  <Breadcrumb />

  <Main pageTitle="Prompt-to-Ontology" class="app-prose">
    <p class="text-muted-foreground text-sm">
      <a
        href={getRelativeLocaleUrl("zh", "projects/prompt-to-ontology")}
        class="text-accent hover:underline"
      >
        阅读中文版
      </a>
    </p>

    <p class="text-muted-foreground text-lg">
      A public experiment on transforming messy product requirements, prompts,
      and business concepts into structured ontology assets for enterprise AI
      systems.
    </p>

    <div class="border-border mt-4 flex flex-wrap gap-2">
      <span class="rounded-full border px-3 py-1 text-xs font-medium">
        Knowledge Graphs
      </span>
      <span class="rounded-full border px-3 py-1 text-xs font-medium">
        Neo4j
      </span>
      <span class="rounded-full border px-3 py-1 text-xs font-medium">
        NetworkX
      </span>
      <span class="rounded-full border px-3 py-1 text-xs font-medium">
        ReAct Agent
      </span>
      <span class="rounded-full border px-3 py-1 text-xs font-medium">
        LLM Pair Programming
      </span>
    </div>

    <div
      class="border-border bg-border mt-6 grid gap-px overflow-hidden rounded-lg border sm:grid-cols-2"
    >
      {
        snapshot.map(item => (
          <div class="bg-background p-4">
            <p class="text-muted-foreground text-xs font-medium tracking-wide uppercase">
              {item.label}
            </p>
            <p class="mt-1 text-sm">{item.value}</p>
          </div>
        ))
      }
    </div>

    <h2 class="mt-8 text-xl font-semibold">The Problem</h2>
    <p>
      Enterprise AI systems often fail because the underlying data model doesn't
      match how the business actually works. Traditional data models show tables
      and columns, but miss the relationships, constraints, and operations that
      define real business logic. When you build an AI agent on top of a bad
      data model, the agent reasons about a fictional version of your business.
    </p>
    <p>
      An ontology captures not just entities and attributes, but relationships,
      constraints, and the actions those entities enable. For enterprise AI,
      this is the difference between a chatbot that gives generic answers and an
      agent that can actually operate on your business context.
    </p>

    <h2 class="mt-6 text-xl font-semibold">My Role</h2>
    <p>
      I ran this as a PM-led build: I defined the product intent, the
      architecture boundaries, and the design constraints, then used LLM pair
      programming (Claude Code) to accelerate implementation, debugging, and
      iteration. Every architectural decision — what the graph models, where
      compute lives, what the agent is allowed to do — was a product decision I
      made and can defend.
    </p>

    <h2 class="mt-6 text-xl font-semibold">Approach: What I Built</h2>
    <p>
      Prompt-to-Ontology takes raw CSV data and transforms it into an
      interactive knowledge graph. An LLM infers the ontology schema — entities,
      relationships, constraints — then writes it into a Neo4j graph database. A
      ReAct agent sits on top, ready to query the graph and suggest business
      actions with human-in-the-loop approval.
    </p>
    <p>
      The architecture separates three concerns: <strong>Neo4j</strong> as the data
      source, <strong>NetworkX</strong> as the compute engine, and the <strong
        >LLM</strong
      > as the reasoning layer. Three decoupled systems that can be independently
      replaced.
    </p>
    <FlowDiagram
      steps={architectureSteps}
      caption="End-to-end pipeline: from raw tabular data to human-approved business actions. Highlighted stages are where the LLM does the reasoning."
    />

    <h2 class="mt-8 text-xl font-semibold">Product Walkthrough</h2>
    <p>
      A working prototype, built end-to-end. Click any screen to enlarge — this
      is the pet-food ontology demo running the full pipeline from raw data to
      agent-suggested, human-approved actions.
    </p>
    <ScreenshotGallery images={walkthrough} />

    <div
      class="border-border bg-muted/30 mt-6 flex flex-col gap-3 rounded-lg border p-5 sm:flex-row sm:items-center sm:justify-between"
    >
      <div>
        <p class="font-medium">See the ontology come alive</p>
        <p class="text-muted-foreground text-sm">
          Explore the knowledge graph as an interactive 3D scene — orbit, zoom,
          and inspect every entity and relationship.
        </p>
      </div>
      <a
        href={getRelativeLocaleUrl("en", "projects/ontology-graph")}
        class="bg-accent text-accent-foreground inline-flex shrink-0 items-center gap-1.5 rounded-md px-5 py-2.5 text-sm font-medium transition-opacity hover:opacity-90"
      >
        Explore in 3D &rarr;
      </a>
    </div>

    <h2 class="mt-8 text-xl font-semibold">Key Insights</h2>
    <p>
      Fact tables are nodes, not edges. An order isn't a relationship between a
      customer and a product — it's an independent entity connected to both via
      separate edges. Get this wrong and your entire graph topology collapses.
    </p>
    <p>
      A knowledge graph without action buttons is just a pretty picture. Every
      node type has context-sensitive operations calculated from its current
      state — a low inventory node lights up a "Create Purchase Order" button.
    </p>

    <h2 class="mt-6 text-xl font-semibold">Outcome & Signals</h2>
    <ul class="mt-2 space-y-2">
      <li>
        A working full-stack prototype: CSV in, operational knowledge graph with
        agent-suggested actions out — in a public GitHub repository.
      </li>
      <li>
        A reusable cognitive framework: the difference between data models,
        schemas, and ontologies; the distinction between "viewing a graph" and
        "operating a business through a graph."
      </li>
      <li>
        The methodology was extracted into the
        <a
          href={getRelativeLocaleUrl(
            config.site.lang,
            "playbook/prompt-to-ontology"
          )}
          class="text-accent hover:underline">Prompt-to-Ontology playbook</a
        > and documented in a
        <a
          href={getRelativeLocaleUrl(
            config.site.lang,
            "posts/building-ontology-os"
          )}
          class="text-accent hover:underline">long-form write-up</a
        >.
      </li>
    </ul>

    <div class="mt-6 flex flex-wrap gap-3">
      <a
        href="https://github.com/wenhaoyu-bryan/prompt-to-ontology"
        class="bg-accent text-accent-foreground inline-flex items-center gap-1.5 rounded-md px-5 py-2.5 text-sm font-medium transition-opacity hover:opacity-90"
        target="_blank"
        rel="noopener noreferrer"
      >
        View on GitHub
      </a>
      <a
        href={getRelativeLocaleUrl(
          config.site.lang,
          "posts/building-ontology-os"
        )}
        class="border-border text-foreground hover:bg-accent/10 inline-flex items-center gap-1.5 rounded-md border px-5 py-2.5 text-sm font-medium transition-colors"
      >
        Read the Blog Post
      </a>
    </div>
  </Main>

  <Footer />
</Layout>
