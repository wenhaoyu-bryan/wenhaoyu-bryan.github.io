---
import { getRelativeLocaleUrl } from "astro:i18n";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Main from "@/components/Main.astro";
import Footer from "@/components/Footer.astro";
import config from "@/config";

const locale = Astro.currentLocale ?? config.site.lang;

// Update the date whenever this page's content changes.
const lastUpdated = "July 20, 2026";

const building = [
  "Leading an enterprise agent platform from 0 to 1 as its product manager — ideation, PRDs, competitor analysis, customer feedback, and vibe-coded prototypes that become the engineering blueprint.",
  "Designing multi-agent sessions and an orchestrator–worker architecture — how specialized agents split work, coordinate, and stay governable.",
  "Growing this site into a bilingual portfolio and knowledge hub for AI product management.",
  "Turning my working toolchain into a documented, reusable operating system for AI PM work.",
];

const exploring = [
  "How ontology and knowledge graphs make enterprise AI more reliable and operational.",
  "How PMs can use vibe coding to validate ideas faster and hand engineering a working blueprint.",
  "How AI search (GEO) changes the way products get discovered and adopted.",
  "Automated model-routing policies and honest cost-effectiveness tracking across my AI stack.",
];

const shipped = [
  'The Enterprise Agent Platform "Current Work" page — a confidentiality-safe walkthrough of the platform I\'m leading, focused on methodology and capabilities rather than internal detail.',
  "Growth Lab, reframed as a public lab notebook — methodology-first, with this site running as Experiment 01.",
  "My AI Stack — a page documenting how I orchestrate coding agents, chat models, and self-built tools, with honest capability boundaries.",
  "AI PM Manifesto — a dark, cinematic single-page frontend/UX craft showcase built with Astro, GSAP, and Lenis.",
  "An interactive 3D ontology graph inside the Prompt-to-Ontology project.",
  "Full Chinese localization of the site's non-blog pages.",
];
---

<Layout
  title={`Now — ${config.site.title}`}
  description="What Wenhao Yu is focused on right now — current projects, what he's exploring, and recently shipped work. A now page in the nownownow.com tradition."
>
  <Header />
  <Breadcrumb />

  <Main pageTitle="Now" class="app-prose">
    <p class="text-muted-foreground text-sm">
      What I'm focused on right now. This is a
      <a href="https://nownownow.com/about" class="text-accent hover:underline"
        >now page</a
      > — a snapshot, not a changelog. Last updated {lastUpdated}.
    </p>

    <h2 class="mt-8 text-xl font-semibold">Building</h2>
    <ul class="mt-2 space-y-2">
      {building.map(item => <li>{item}</li>)}
    </ul>

    <h2 class="mt-8 text-xl font-semibold">Exploring</h2>
    <ul class="mt-2 space-y-2">
      {exploring.map(item => <li>{item}</li>)}
    </ul>

    <h2 class="mt-8 text-xl font-semibold">Recently Shipped</h2>
    <ul class="mt-2 space-y-2">
      {shipped.map(item => <li>{item}</li>)}
    </ul>

    <div class="border-border mt-10 rounded-lg border p-6">
      <h2 class="text-lg font-semibold">Elsewhere</h2>
      <div class="mt-3 flex flex-wrap gap-3">
        <a
          href={getRelativeLocaleUrl(locale, "ai-stack")}
          class="text-accent hover:underline"
        >
          My AI Stack
        </a>
        <a
          href={getRelativeLocaleUrl(locale, "projects")}
          class="text-accent hover:underline"
        >
          Projects
        </a>
        <a
          href={getRelativeLocaleUrl(locale, "about")}
          class="text-accent hover:underline"
        >
          About
        </a>
      </div>
    </div>
  </Main>

  <Footer />
</Layout>
