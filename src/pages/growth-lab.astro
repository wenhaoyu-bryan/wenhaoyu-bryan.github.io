---
import { getRelativeLocaleUrl } from "astro:i18n";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Main from "@/components/Main.astro";
import Footer from "@/components/Footer.astro";
import config from "@/config";

const locale = Astro.currentLocale ?? config.site.lang;

type Experiment = {
  number: string;
  title: string;
  status: string;
  hypothesis: string;
  built: string[];
  measuring: string;
  openQuestions: string[];
};

const experiments: Experiment[] = [
  {
    number: "01",
    title: "This site as a GEO testbed",
    status: "Running",
    hypothesis:
      "A static site engineered for machine readability — clean metadata, structured data, and AI-readable content endpoints — gets read and cited more accurately by AI answer engines than a conventional blog does.",
    built: [
      "llms.txt (index) and llms-full.txt (complete content) endpoints, assembled at build time from the same data the pages render from",
      "Dynamic OG images generated with satori, so every page ships a titled social card instead of a bare link",
      "JSON-LD structured data (Person, WebSite, BlogPosting) so search and answer engines can parse identity and content unambiguously",
      "“Ask Claude / ChatGPT about me” deep-links that pre-load the llms-full content into a chat",
    ],
    measuring:
      "Indexed pages, organic impressions on niche AI-PM queries, and whether AI-search tools cite the site accurately when asked about me.",
    openQuestions: [
      "Does llms-full.txt measurably change how accurately AI engines summarize me, or is it ignored?",
      "Which structured-data types actually influence answer-engine citations versus classic search snippets?",
      "How should a product be written so that both humans and answer engines understand it on the first pass?",
    ],
  },
];
---

<Layout
  title={`Growth Lab — ${config.site.title}`}
  description="A public lab notebook of SEO and GEO experiments — from the SEO foundations I built at Leiga to using this site as an AI-search testbed."
  ogImage="/og/growth-lab.png"
>
  <Header />
  <Breadcrumb />

  <Main pageTitle="Growth Lab" class="app-prose">
    <p>
      Growth Lab is a public lab notebook. Instead of writing growth advice in
      the abstract, I run experiments in the open — starting with the one
      property I fully control: this site.
    </p>
    <p>
      Every entry follows the same loop: state a <strong>hypothesis</strong>,
      <strong>build</strong> the smallest thing that tests it, decide what to
      <strong>measure</strong>, and record the <strong>open questions</strong> it
      raises. The through-line is GEO — how generative answer engines are changing
      organic growth — and the machine-readable, structured-content techniques that
      come with it.
    </p>

    <h2 class="mt-8 text-xl font-semibold">Experiment Log</h2>
    <div class="mt-4 space-y-6">
      <article class="border-border rounded-lg border p-6">
        <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1">
          <span class="text-accent text-sm font-medium">Experiment 00</span>
          <h3 class="text-lg font-medium">Building SEO foundations at Leiga</h3>
          <span
            class="border-border text-muted-foreground rounded-full border px-2.5 py-0.5 text-xs whitespace-nowrap"
          >
            Concluded · Aug 2024
          </span>
        </div>
        <div class="mt-4 space-y-4">
          <div>
            <span class="text-accent text-sm font-medium">The situation</span>
            <p class="text-muted-foreground mt-1">
              <a
                href="https://leiga.com"
                target="_blank"
                rel="noopener noreferrer"
                class="text-accent hover:underline">Leiga</a
              >, an AI-powered project-management SaaS, needed organic
              discoverability essentially from scratch. I joined the Product
              Growth & Development team from May to August 2024 to build the
              foundations a growing SaaS needs to be found — and to make them
              durable enough to keep working after I moved on.
            </p>
          </div>
          <div>
            <span class="text-accent text-sm font-medium">What I built</span>
            <ul class="text-muted-foreground mt-1 list-disc space-y-1 pl-5">
              <li>
                Technical SEO groundwork — sitemap and robots configuration,
                canonical URLs, redirect hygiene, and crawlability and
                indexation fixes.
              </li>
              <li>
                Metadata systems — title and description patterns and Open Graph
                tags applied consistently across page types.
              </li>
              <li>
                Structured data — schema.org markup on the page types that
                mattered, so search and answer engines could parse them
                unambiguously.
              </li>
              <li>
                Content architecture — URL structure, internal linking, and a
                page-type taxonomy spanning <a
                  href="https://www.leiga.com/use-case-product-manager"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-accent hover:underline">Use-case pages</a
                >, the <a
                  href="https://www.leiga.com/feature"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-accent hover:underline">Features page</a
                >, <a
                  href="https://www.leiga.com/resources"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-accent hover:underline">Resources</a
                >, and <a
                  href="https://www.leiga.com/compare"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-accent hover:underline">Comparison pages</a
                >.
              </li>
              <li>
                Documentation site — rebuilt Leiga's product guide and help
                center (<a
                  href="https://guide.leiga.com"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-accent hover:underline">guide.leiga.com</a
                >).
              </li>
              <li>
                Programmatic landing-page infrastructure — templated page
                systems designed to scale across keyword families, like the <a
                  href="https://www.leiga.com/free-tools"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-accent hover:underline">free-tools pages</a
                >, whose content and tool-name keyword planning I worked on with
                the dev team.
              </li>
              <li>
                Keyword research and keyword-to-page mapping — deciding which
                pages should exist and what each one should target.
              </li>
              <li>
                Content distribution — ran social-media promotion for the
                published articles.
              </li>
              <li>
                Measurement setup — Search Console and analytics instrumentation
                to track the work (the setup only — never what the data showed).
              </li>
            </ul>
            <p class="text-muted-foreground mt-2 text-sm">
              The linked pages are live examples of each page type, not claims
              about their current performance or ownership.
            </p>
          </div>
          <div>
            <span class="text-accent text-sm font-medium">
              Decisions worth recording
            </span>
            <ul class="text-muted-foreground mt-1 list-disc space-y-1 pl-5">
              <li>
                Templated systems for anything that scaled by keyword family —
                free-tools and comparison pages — and hand-written editorial
                only where a page needed a genuine point of view.
              </li>
              <li>
                Foundations before volume: canonicals, metadata patterns, and
                internal-linking rules first, so every page published afterward
                inherited them instead of being retrofitted.
              </li>
            </ul>
          </div>
          <div>
            <span class="text-accent text-sm font-medium">
              What it taught me
            </span>
            <ul class="text-muted-foreground mt-1 list-disc space-y-1 pl-5">
              <li>
                SEO infrastructure is a product surface, not a marketing
                checkbox — it has schemas, templates, and edge cases like any
                system you design and maintain.
              </li>
              <li>
                Internal linking is information architecture: choosing which
                pages exist and how they connect is the same discipline as
                designing a product's navigation.
              </li>
              <li>
                Foundations compound after you leave — I went back and found
                most of the SEO work still in place, which is exactly why "still
                live" is the outcome I cite instead of a traffic number.
              </li>
              <li>
                This was 2024 work, before answer engines reshaped discovery —
                the gap Experiment 01 picks up.
              </li>
            </ul>
          </div>
          <div>
            <span class="text-accent text-sm font-medium">
              Why there are no numbers here
            </span>
            <p class="text-muted-foreground mt-1">
              The performance data belongs to Leiga, so this lab publishes
              numbers only when I own them — the work is described here with the
              company's blessing; the results are theirs to report.
            </p>
          </div>
        </div>
      </article>
      {
        experiments.map(exp => (
          <article class="border-border rounded-lg border p-6">
            <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1">
              <span class="text-accent text-sm font-medium">
                Experiment {exp.number}
              </span>
              <h3 class="text-lg font-medium">{exp.title}</h3>
              <span class="border-border text-muted-foreground rounded-full border px-2.5 py-0.5 text-xs whitespace-nowrap">
                {exp.status}
              </span>
            </div>
            <div class="mt-4 space-y-4">
              <div>
                <span class="text-accent text-sm font-medium">Hypothesis</span>
                <p class="text-muted-foreground mt-1">{exp.hypothesis}</p>
              </div>
              <div>
                <span class="text-accent text-sm font-medium">
                  What I built
                </span>
                <ul class="text-muted-foreground mt-1 list-disc space-y-1 pl-5">
                  {exp.built.map(b => (
                    <li>{b}</li>
                  ))}
                </ul>
              </div>
              <div>
                <span class="text-accent text-sm font-medium">
                  What I'm measuring
                </span>
                <p class="text-muted-foreground mt-1">{exp.measuring}</p>
              </div>
              <div>
                <span class="text-accent text-sm font-medium">
                  Open questions
                </span>
                <ul class="text-muted-foreground mt-1 list-disc space-y-1 pl-5">
                  {exp.openQuestions.map(q => (
                    <li>{q}</li>
                  ))}
                </ul>
              </div>
            </div>
          </article>
        ))
      }
    </div>

    <div class="border-border mt-10 rounded-lg border p-6">
      <h2 class="text-lg font-semibold">Related</h2>
      <div class="mt-3 flex flex-wrap gap-3">
        <a
          href={getRelativeLocaleUrl(locale, "posts")}
          class="text-accent hover:underline"
        >
          Writing
        </a>
        <a
          href={getRelativeLocaleUrl(locale, "projects")}
          class="text-accent hover:underline"
        >
          Projects
        </a>
        <a
          href={getRelativeLocaleUrl(locale, "playbook/seo-to-geo")}
          class="text-accent hover:underline"
        >
          SEO to GEO Playbook
        </a>
      </div>
    </div>
  </Main>

  <Footer />
</Layout>
