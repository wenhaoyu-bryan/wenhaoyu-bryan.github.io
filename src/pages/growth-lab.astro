---
import { getRelativeLocaleUrl } from "astro:i18n";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Main from "@/components/Main.astro";
import Footer from "@/components/Footer.astro";
import config from "@/config";

const locale = Astro.currentLocale ?? config.site.lang;

const experiments = [
  {
    hypothesis:
      "A well-structured static site with proper meta, sitemap, and content architecture can rank for niche AI PM keywords.",
    built: "This personal site on Astro + GitHub Pages.",
    measured: "Organic traffic, indexed pages, AI search citations.",
    learned: "In progress.",
    next: "Publish more content, track GEO performance.",
  },
  {
    hypothesis:
      "Publishing an llms.txt / llms-full.txt (the llmstxt.org convention) makes the site easier for AI answer engines to read and cite accurately — a GEO analogue to the sitemap.",
    built:
      "Build-time llms.txt (index) and llms-full.txt (complete content) endpoints, assembled from the same data the site renders from, plus 'Ask Claude / ChatGPT about me' deep-links that pre-load that content.",
    measured: "AI-search citations, referral traffic from AI chat tools.",
    learned: "In progress.",
    next: "Watch whether AI engines cite the site more accurately over time.",
  },
];
---

<Layout
  title={`Growth Lab | ${config.site.title}`}
  description="A public notebook for SEO, GEO, B2B content systems, and AI-search-aware growth experiments by an AI Product Manager."
>
  <Header />
  <Breadcrumb />

  <Main pageTitle="Growth Lab" class="app-prose">
    <p>
      A public notebook for SEO, GEO, B2B content systems, and AI-search-aware
      growth experiments.
    </p>

    <h2 class="mt-8 text-xl font-semibold">Why Growth Matters for AI PMs</h2>
    <p>
      AI products do not win only because the model is good. They also need
      distribution, positioning, trust, and repeatable demand generation. An AI
      PM who understands growth can connect product decisions to adoption
      outcomes.
    </p>

    <h2 class="mt-6 text-xl font-semibold">What I Experiment With</h2>
    <ul class="mt-2 space-y-2">
      <li>SEO keyword architecture</li>
      <li>GEO / AI search visibility</li>
      <li>B2B content systems</li>
      <li>SaaS tool site ideas</li>
      <li>Personal site as SEO/GEO experiment</li>
    </ul>

    <h2 class="mt-6 text-xl font-semibold">Current Questions</h2>
    <ul class="mt-2 space-y-2">
      <li>
        How should products be written so both humans and AI answer engines
        understand them?
      </li>
      <li>How do B2B companies build topical authority?</li>
      <li>What does GEO change compared with traditional SEO?</li>
      <li>How can AI PMs connect product thinking with growth loops?</li>
    </ul>

    <h2 class="mt-8 text-xl font-semibold">Privacy and Sanitization Rules</h2>
    <p>
      Growth Lab will include public notes and future sanitized case studies on
      SEO, GEO, B2B content systems, and AI-search-aware growth.
    </p>
    <p>
      I do not publish raw client data, company dashboards, internship
      materials, internal analytics screenshots, private domains, keyword lists,
      or confidential metrics.
    </p>
    <p>
      When I write about past growth work, I will use anonymized, normalized, or
      redrawn examples. The goal is to share reusable growth thinking, not
      expose private business information.
    </p>

    <h2 class="mt-8 text-xl font-semibold">Future Case Study Format</h2>
    <p>Future case studies will follow a lightweight structure:</p>
    <ul class="mt-2 space-y-2">
      <li>Context</li>
      <li>Problem</li>
      <li>Hypothesis</li>
      <li>What I changed</li>
      <li>What I measured</li>
      <li>What I learned</li>
      <li>Reusable framework</li>
    </ul>
    <p class="text-muted-foreground mt-2 text-sm">
      Detailed experiment cards will be added later when the cases are mature
      and properly sanitized.
    </p>

    <h2 class="mt-6 text-xl font-semibold">Experiment Log</h2>
    <div class="mt-4 space-y-6">
      {
        experiments.map(exp => (
          <div class="border-border rounded-lg border p-6">
            <div class="space-y-3">
              <div>
                <span class="text-accent text-sm font-medium">Hypothesis</span>
                <p class="text-muted-foreground mt-1">{exp.hypothesis}</p>
              </div>
              <div>
                <span class="text-accent text-sm font-medium">
                  What I built
                </span>
                <p class="text-muted-foreground mt-1">{exp.built}</p>
              </div>
              <div>
                <span class="text-accent text-sm font-medium">
                  What I measured
                </span>
                <p class="text-muted-foreground mt-1">{exp.measured}</p>
              </div>
              <div>
                <span class="text-accent text-sm font-medium">
                  What I learned
                </span>
                <p class="text-muted-foreground mt-1">{exp.learned}</p>
              </div>
              <div>
                <span class="text-accent text-sm font-medium">Next step</span>
                <p class="text-muted-foreground mt-1">{exp.next}</p>
              </div>
            </div>
          </div>
        ))
      }
    </div>

    <div class="border-border mt-10 rounded-lg border p-6">
      <h2 class="text-lg font-semibold">Related</h2>
      <div class="mt-3 flex flex-wrap gap-3">
        <a
          href={getRelativeLocaleUrl(locale, "posts")}
          class="text-accent hover:underline"
        >
          Writing
        </a>
        <a
          href={getRelativeLocaleUrl(locale, "projects")}
          class="text-accent hover:underline"
        >
          Projects
        </a>
        <a
          href={getRelativeLocaleUrl(locale, "playbook/seo-to-geo")}
          class="text-accent hover:underline"
        >
          SEO to GEO Playbook
        </a>
      </div>
    </div>
  </Main>

  <Footer />
</Layout>
