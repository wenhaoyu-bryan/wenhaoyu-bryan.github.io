---
import { getRelativeLocaleUrl } from "astro:i18n";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Main from "@/components/Main.astro";
import Footer from "@/components/Footer.astro";
import config from "@/config";

const locale = Astro.currentLocale ?? config.site.lang;

const sections = [
  {
    title: "SEO / GEO Notes",
    description:
      "Keyword research, content architecture, AI search visibility, LLM-friendly content structure, and programmatic SEO ideas.",
    topics: [
      "Keyword architecture for B2B SaaS",
      "LLM-friendly content structure",
      "From SEO to GEO: adapting for AI search",
      "Programmatic SEO patterns",
    ],
  },
  {
    title: "B2B Website Experiments",
    description:
      "Hands-on experiments with B2B content systems, product-site structure, and technical SEO.",
    topics: [
      "B2B packaging SEO",
      "SaaS tool-site exploration",
      "Technical SEO for static sites",
    ],
  },
  {
    title: "Independent Site Exploration",
    description:
      "Side projects around Shopify, independent e-commerce, and personal site as a growth experiment.",
    topics: [
      "Shopify / independent e-commerce",
      "Personal site as SEO/GEO experiment",
      "Content-driven growth loops",
    ],
  },
];

const experiments = [
  {
    hypothesis:
      "A well-structured static site with proper meta, sitemap, and content architecture can rank for niche AI PM keywords.",
    built: "This personal site on Astro + GitHub Pages.",
    measured: "Organic traffic, indexed pages, AI search citations.",
    learned: "In progress.",
    next: "Publish more content, track GEO performance.",
  },
];
---

<Layout
  title={`Growth Lab | ${config.site.title}`}
  description="Experiments and notes on SEO, GEO, AI search visibility, B2B websites, SaaS tool sites, and independent growth systems."
>
  <Header />

  <Main pageTitle="Growth Lab" class="app-prose">
    <p>
      Growth Lab is where I document experiments around SEO, GEO, AI search
      visibility, B2B websites, SaaS tool sites, and independent growth
      systems.
    </p>

    <p class="text-muted-foreground text-sm">
      I care not only about building AI products, but also about how products
      are discovered, trusted, and adopted.
    </p>

    <div class="mt-8 space-y-8">
      {
        sections.map(section => (
          <section>
            <h2 class="text-xl font-semibold">{section.title}</h2>
            <p class="text-muted-foreground mt-2">{section.description}</p>
            <ul class="mt-3 space-y-2">
              {section.topics.map(topic => (
                <li class="text-muted-foreground flex items-start gap-2">
                  <span class="text-accent mt-1">&#x2022;</span>
                  <span>{topic}</span>
                </li>
              ))}
            </ul>
          </section>
        ))
      }
    </div>

    <h2 class="mt-10 text-xl font-semibold">Experiment Log</h2>
    <div class="mt-4 space-y-6">
      {
        experiments.map(exp => (
          <div class="border-border rounded-lg border p-6">
            <div class="space-y-3">
              <div>
                <span class="text-sm font-medium text-accent">Hypothesis</span>
                <p class="text-muted-foreground mt-1">{exp.hypothesis}</p>
              </div>
              <div>
                <span class="text-sm font-medium text-accent">What I built</span>
                <p class="text-muted-foreground mt-1">{exp.built}</p>
              </div>
              <div>
                <span class="text-sm font-medium text-accent">
                  What I measured
                </span>
                <p class="text-muted-foreground mt-1">{exp.measured}</p>
              </div>
              <div>
                <span class="text-sm font-medium text-accent">
                  What I learned
                </span>
                <p class="text-muted-foreground mt-1">{exp.learned}</p>
              </div>
              <div>
                <span class="text-sm font-medium text-accent">Next step</span>
                <p class="text-muted-foreground mt-1">{exp.next}</p>
              </div>
            </div>
          </div>
        ))
      }
    </div>

    <div class="border-border mt-10 rounded-lg border p-6">
      <h2 class="text-lg font-semibold">Related</h2>
      <div class="mt-3 flex flex-wrap gap-3">
        <a
          href={getRelativeLocaleUrl(locale, "posts")}
          class="text-accent hover:underline"
        >
          Writing
        </a>
        <a
          href={getRelativeLocaleUrl(locale, "projects")}
          class="text-accent hover:underline"
        >
          Projects
        </a>
      </div>
    </div>
  </Main>

  <Footer />
</Layout>
