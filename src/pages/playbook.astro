---
import { getRelativeLocaleUrl } from "astro:i18n";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Main from "@/components/Main.astro";
import Footer from "@/components/Footer.astro";
import config from "@/config";

const locale = Astro.currentLocale ?? config.site.lang;

const PLAYBOOK_BASE =
  "https://wenhaoyu-bryan.github.io/AI-PM-Operating-Playbook/";

const categories = [
  {
    title: "AI-Native Product Delivery",
    items: [
      {
        label: "Vibe Coding for Product Discovery",
        href: getRelativeLocaleUrl(locale, "playbook/vibe-coding"),
        status: "live",
      },
      {
        label: "Harness Engineering",
        href: getRelativeLocaleUrl(locale, "playbook/harness-engineering"),
        status: "live",
      },
      {
        label: "Loop Engineering",
        href: getRelativeLocaleUrl(locale, "playbook/loop-engineering"),
        status: "live",
      },
      {
        label: "AI-Native PRD",
        href: getRelativeLocaleUrl(locale, "playbook/ai-native-prd"),
        status: "live",
      },
      {
        label: "PRD to Prototype Workflow",
        href: getRelativeLocaleUrl(locale, "playbook/prd-to-prototype"),
        status: "live",
      },
    ],
  },
  {
    title: "Agent Product Design",
    items: [
      {
        label: "Agent Product Design Framework",
        href: getRelativeLocaleUrl(locale, "playbook/agent-product-design"),
        status: "live",
      },
      { label: "Human-in-the-Loop Design", href: null, status: "planned" },
      { label: "Autonomy and Tool Boundaries", href: null, status: "planned" },
      { label: "Agent Evaluation", href: null, status: "planned" },
    ],
  },
  {
    title: "Ontology and Knowledge Systems",
    items: [
      {
        label: "Prompt-to-Ontology",
        href: getRelativeLocaleUrl(locale, "playbook/prompt-to-ontology"),
        status: "live",
      },
      { label: "Ontology for RAG and Agents", href: null, status: "planned" },
      {
        label: "Objects, Relationships, States, and Actions",
        href: null,
        status: "planned",
      },
    ],
  },
  {
    title: "Building in Public",
    items: [
      {
        label: "Building AI PM Operating Playbook",
        href: null,
        status: "planned",
      },
      {
        label: "Lessons from PM-Led Prototyping",
        href: null,
        status: "planned",
      },
    ],
  },
];
---

<Layout
  title={`AI PM Operating Playbook | ${config.site.title}`}
  description="Frameworks, field notes, and practical patterns for designing, evaluating, and delivering AI-native products."
>
  <Header />
  <Breadcrumb />

  <Main pageTitle="AI PM Operating Playbook" class="app-prose">
    <p>
      Frameworks, field notes, and practical patterns for designing, evaluating,
      and delivering AI-native products.
    </p>

    <div class="mt-6 mb-8">
      <a
        href={PLAYBOOK_BASE}
        class="bg-accent text-accent-foreground inline-flex items-center gap-1.5 rounded-md px-5 py-2.5 text-sm font-medium transition-opacity hover:opacity-90"
        target="_blank"
        rel="noopener noreferrer"
      >
        Open Interactive Tools ↗
      </a>
    </div>

    <div class="mt-8 space-y-8">
      {
        categories.map(category => (
          <section>
            <h2 class="text-xl font-semibold">{category.title}</h2>
            <ul class="mt-3 space-y-2">
              {category.items.map(item => (
                <li class="text-muted-foreground flex items-start gap-2">
                  <span class="text-accent mt-1">&#x2022;</span>
                  {item.href ? (
                    <a href={item.href} class="text-accent hover:underline">
                      {item.label}
                    </a>
                  ) : (
                    <span>{item.label}</span>
                  )}
                  {item.status === "planned" && (
                    <span class="text-muted-foreground mt-0.5 text-xs">
                      (coming soon)
                    </span>
                  )}
                </li>
              ))}
            </ul>
          </section>
        ))
      }
    </div>

    <div class="border-border mt-10 rounded-lg border p-6">
      <h2 class="text-lg font-semibold">Methodology and Tools</h2>
      <p class="text-muted-foreground mt-2 text-sm">
        This website contains the essays and frameworks. AI PM Operating
        Playbook provides the interactive tools that apply them.
      </p>
      <div class="mt-4 flex flex-wrap gap-3">
        <a
          href={getRelativeLocaleUrl(locale, "posts")}
          class="text-accent hover:underline"
        >
          Browse Articles
        </a>
        <a
          href={PLAYBOOK_BASE}
          class="text-accent hover:underline"
          target="_blank"
          rel="noopener noreferrer"
        >
          Open Quick Tools ↗
        </a>
        <a
          href="https://github.com/wenhaoyu-bryan/AI-PM-Operating-Playbook"
          class="text-accent hover:underline"
          target="_blank"
          rel="noopener noreferrer"
        >
          View Source ↗
        </a>
      </div>
    </div>
  </Main>

  <Footer />
</Layout>
