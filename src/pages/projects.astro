---
import { getRelativeLocaleUrl } from "astro:i18n";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Main from "@/components/Main.astro";
import Footer from "@/components/Footer.astro";
import config from "@/config";

const locale = Astro.currentLocale ?? config.site.lang;

const projects = [
  {
    title: "Prompt-to-Ontology",
    description:
      "A public experiment on transforming messy product requirements, prompts, and business concepts into structured ontology assets for enterprise AI systems.",
    status: "Public",
    href: getRelativeLocaleUrl(locale, "projects/prompt-to-ontology"),
    tags: ["Knowledge Graphs", "Neo4j", "Ontology", "ReAct Agent"],
  },
  {
    title: "AI PM Playbook",
    description:
      "A living public playbook for AI Product Managers working with agents, prototypes, PRDs, ontology, and AI-native workflows.",
    status: "In progress",
    href: getRelativeLocaleUrl(locale, "playbook"),
    tags: ["Frameworks", "Playbook", "AI PM"],
  },
  {
    title: "Vibe Coding Prototype Lab",
    description:
      "A collection of public and sanitized experiments showing how AI PMs can use Claude Code, Cursor, and modern AI coding workflows to turn ideas into prototypes.",
    status: "Public",
    href: "https://github.com/wenhaoyu-bryan/prompt-to-ontology",
    tags: ["Claude Code", "Cursor", "Prototyping"],
  },
  {
    title: "SEO/GEO Growth Experiments",
    description:
      "Experiments on building content systems, B2B websites, and AI-search-aware growth loops.",
    status: "Ongoing",
    href: getRelativeLocaleUrl(locale, "growth-lab"),
    tags: ["SEO", "GEO", "B2B", "Content Systems"],
  },
];
---

<Layout
  title={`Projects | ${config.site.title}`}
  description="Public projects and experiments around AI product management, Prompt-to-Ontology, vibe coding prototypes, and SEO/GEO growth systems."
>
  <Header />

  <Main pageTitle="Projects" class="app-prose">
    <p>
      A collection of public projects, prototypes, and experiments around AI
      product management, ontology-driven systems, vibe coding, and growth.
    </p>

    <p class="text-muted-foreground text-sm">
      Some work is private due to data and permission constraints. These pages
      abstract the product methodology rather than exposing internal systems.
    </p>

    <div class="mt-8 grid gap-6">
      {
        projects.map(project => (
          <a
            href={project.href}
            class="border-border group rounded-lg border p-6 transition-colors hover:bg-accent/5"
            {...(project.href.startsWith("http")
              ? { target: "_blank", rel: "noopener noreferrer" }
              : {})}
          >
            <div class="flex items-center justify-between">
              <h2 class="text-xl font-semibold group-hover:text-accent">
                {project.title}
              </h2>
              <span class="text-muted-foreground rounded-full border px-2.5 py-0.5 text-xs">
                {project.status}
              </span>
            </div>
            <p class="text-muted-foreground mt-2">{project.description}</p>
            <div class="mt-3 flex flex-wrap gap-2">
              {project.tags.map(tag => (
                <span class="bg-muted rounded-full px-2.5 py-0.5 text-xs">
                  {tag}
                </span>
              ))}
            </div>
          </a>
        ))
      }
    </div>
  </Main>

  <Footer />
</Layout>
