---
import { getRelativeLocaleUrl } from "astro:i18n";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Main from "@/components/Main.astro";
import Footer from "@/components/Footer.astro";
import config from "@/config";

const locale = Astro.currentLocale ?? config.site.lang;

const projects = [
  {
    title: "Prompt-to-Ontology",
    description:
      "A public experiment turning messy requirements and business concepts into ontology assets: entities, relationships, constraints, and action-ready knowledge graphs for enterprise AI systems.",
    status: "Public",
    href: getRelativeLocaleUrl(locale, "projects/prompt-to-ontology"),
    tags: ["Ontology", "Knowledge Graphs", "Neo4j", "NetworkX", "ReAct Agent"],
  },
  {
    title: "AI PM Operating Playbook",
    description:
      "A methodology-driven toolkit that turns ambiguous AI product ideas into structured product briefs, workflow specifications, evaluation plans, and coding-agent handoff materials.",
    status: "Public Tool",
    href: "https://wenhaoyu-bryan.github.io/AI-PM-Operating-Playbook/",
    tags: ["AI PM", "Methodology", "Interactive Tools", "Frameworks"],
  },
  {
    title: "Vibe Coding Prototype Lab",
    description:
      "A public lab showing how PM-led LLM pair programming can turn ambiguous ideas into prototypes, specs, and reusable product workflows.",
    status: "Public",
    href: getRelativeLocaleUrl(locale, "projects/vibe-coding-prototype-lab"),
    tags: ["Claude Code", "Cursor", "Prototyping", "LLM Pair Programming"],
  },
  {
    title: "SEO/GEO Growth Experiments",
    description:
      "Experiments on content systems, B2B websites, and AI-search-aware growth loops — connecting SEO fundamentals with GEO visibility.",
    status: "Ongoing",
    href: getRelativeLocaleUrl(locale, "growth-lab"),
    tags: ["SEO", "GEO", "B2B", "Content Systems"],
  },
];
---

<Layout
  title={`Projects | ${config.site.title}`}
  description="Public projects and experiments around AI product management, Prompt-to-Ontology, vibe coding prototypes, and SEO/GEO growth systems."
>
  <Header />

  <Main pageTitle="Projects" class="app-prose">
    <p class="text-muted-foreground text-sm">
      <a
        href={getRelativeLocaleUrl("zh", "projects")}
        class="text-accent hover:underline"
      >
        阅读中文版
      </a>
    </p>

    <p>
      A collection of public projects, prototypes, and experiments around AI
      product management, ontology-driven systems, vibe coding, and growth.
    </p>

    <p class="text-muted-foreground text-sm">
      Some work is private due to data and permission constraints. These pages
      abstract the product methodology rather than exposing internal systems.
    </p>

    <div class="mt-8 grid gap-6">
      {
        projects.map(project => (
          <a
            href={project.href}
            class="border-border group hover:bg-accent/5 rounded-lg border p-6 transition-colors"
            {...(project.href.startsWith("http")
              ? { target: "_blank", rel: "noopener noreferrer" }
              : {})}
          >
            <div class="flex items-center justify-between">
              <h2 class="group-hover:text-accent text-xl font-semibold">
                {project.title}
              </h2>
              <span class="text-muted-foreground rounded-full border px-2.5 py-0.5 text-xs">
                {project.status}
              </span>
            </div>
            <p class="text-muted-foreground mt-2">{project.description}</p>
            <div class="mt-3 flex flex-wrap gap-2">
              {project.tags.map(tag => (
                <span class="bg-muted rounded-full px-2.5 py-0.5 text-xs">
                  {tag}
                </span>
              ))}
            </div>
          </a>
        ))
      }
    </div>
  </Main>

  <Footer />
</Layout>
