---
import { getRelativeLocaleUrl } from "astro:i18n";
import { Image } from "astro:assets";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Main from "@/components/Main.astro";
import Footer from "@/components/Footer.astro";
import config from "@/config";
import { getProjects } from "@/data/projects";

const locale = Astro.currentLocale ?? config.site.lang;

const projects = getProjects(locale);

// ItemList schema: exposes the project portfolio (incl. repo links) to
// search engines and AI crawlers, mirroring llms.txt.
const base = config.site.url.replace(/\/$/, "");
const projectsJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Projects — Wenhao Yu",
  itemListElement: projects.map((p, i) => ({
    "@type": "ListItem",
    position: i + 1,
    item: {
      "@type": "CreativeWork",
      name: p.title,
      description: p.description,
      url: p.external ? p.href : `${base}${p.href}`,
      ...(p.repo ? { sameAs: [p.repo] } : {}),
      keywords: p.tags.join(", "),
      author: { "@type": "Person", name: config.site.author, url: base },
    },
  })),
});
---

<Layout
  title={`Projects — ${config.site.title}`}
  description="Public projects and case studies: an enterprise agent platform, Prompt-to-Ontology, Agent Anatomy, an AI PM playbook, and growth experiments."
  ogImage="/og/projects.png"
>
  <script
    is:inline
    type="application/ld+json"
    set:html={projectsJsonLd}
    slot="head"
  />
  <Header />
  <Breadcrumb />

  <Main pageTitle="Projects" class="app-prose">
    <p class="text-muted-foreground text-sm">
      <a
        href={getRelativeLocaleUrl("zh", "projects")}
        class="text-accent hover:underline"
      >
        阅读中文版
      </a>
    </p>

    <p>
      A collection of public projects, prototypes, and case studies — from an
      enterprise agent platform to ontology-driven systems, interactive
      explainers, and growth experiments.
    </p>

    <p class="text-muted-foreground text-sm">
      Some work is private due to data and permission constraints. These pages
      abstract the product methodology rather than exposing internal systems.
    </p>

    <div class="mt-8 grid gap-6">
      {
        projects.map(project => (
          <a
            href={project.href}
            class="border-border group hover:bg-accent/5 rounded-lg border p-6 transition-colors"
            {...(project.href.startsWith("http")
              ? { target: "_blank", rel: "noopener noreferrer" }
              : {})}
          >
            {project.thumbnail && (
              <Image
                src={project.thumbnail}
                alt={project.thumbnailAlt ?? project.title}
                widths={[400, 800]}
                sizes="(min-width: 640px) 700px, 90vw"
                class="mb-4 aspect-video w-full rounded-md object-cover object-top"
                loading="lazy"
              />
            )}
            <div class="flex items-center justify-between">
              <h2 class="group-hover:text-accent text-xl font-semibold">
                {project.title}
              </h2>
              <span class="text-muted-foreground rounded-full border px-2.5 py-0.5 text-xs">
                {project.status}
              </span>
            </div>
            <p class="text-muted-foreground mt-2">{project.description}</p>
            <div class="mt-3 flex flex-wrap gap-2">
              {project.tags.map(tag => (
                <span class="bg-muted rounded-full px-2.5 py-0.5 text-xs">
                  {tag}
                </span>
              ))}
            </div>
          </a>
        ))
      }
    </div>
  </Main>

  <Footer />
</Layout>
