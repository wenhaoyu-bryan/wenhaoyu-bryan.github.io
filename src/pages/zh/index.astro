---
import { getRelativeLocaleUrl } from "astro:i18n";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import config from "@/config";
import { getProjects } from "@/data/projects";
import AskAI from "@/components/AskAI.astro";

const locale = "zh";

const topics = [
  {
    title: "智能体工作流",
    description: "设计具备工具、记忆和治理能力的智能体系统。",
  },
  {
    title: "本体驱动 AI 产品",
    description: "使用知识图谱和结构化本体提升企业 AI 可靠性。",
  },
  {
    title: "Harness Engineering",
    description: "设计上下文、工具、约束和反馈系统，引导 AI 编码智能体。",
  },
  {
    title: "Loop Engineering",
    description: "设计反馈循环，使 AI 产品、团队和交付物在迭代中持续改进。",
  },
  {
    title: "面向 PM 的 Vibe Coding",
    description:
      "PM 主导、编码智能体辅助的原型开发，用于早期发现和工作流验证。",
  },
  {
    title: "工业与 B2B AI",
    description: "企业 AI 落地、工业运营和 B2B 产品场景。",
  },
];

const projects = getProjects(locale);

const featured = [
  {
    title: "Building Ontology OS",
    description: "本体驱动的 AI 产品实验（英文）",
    href: getRelativeLocaleUrl("en", "posts/building-ontology-os"),
  },
  {
    title: "Harness Engineering",
    description: "上下文、工具与约束设计",
    href: getRelativeLocaleUrl("zh", "playbook/harness-engineering"),
  },
  {
    title: "AI-Native PRD",
    description: "AI 原生产品需求文档",
    href: getRelativeLocaleUrl("zh", "playbook/ai-native-prd"),
  },
  {
    title: "Loop Engineering",
    description: "反馈循环与迭代设计",
    href: getRelativeLocaleUrl("zh", "playbook/loop-engineering"),
  },
  {
    title: "Vibe Coding",
    description: "PM 主导的原型方法论",
    href: getRelativeLocaleUrl("zh", "playbook/vibe-coding"),
  },
  {
    title: "SEO to GEO",
    description: "搜索与 AI 可见性",
    href: getRelativeLocaleUrl("zh", "playbook/seo-to-geo"),
  },
  {
    title: "Prompt-to-Ontology",
    description: "本体驱动知识系统",
    href: getRelativeLocaleUrl(locale, "projects/prompt-to-ontology"),
  },
];
---

<Layout
  title={`${config.site.title}`}
  description="余文豪的 AI 产品经理个人网站，关注 Agent 工作流、本体驱动系统、Vibe Coding 和 SEO/GEO 增长。"
>
  <Header />
  <main id="main-content" data-layout="index" class="app-layout">
    <!-- Hero -->
    <section class="border-border border-b pt-8 pb-10 sm:pt-12 sm:pb-14">
      <div
        class="flex flex-col gap-6 sm:flex-row sm:items-center sm:justify-between"
      >
        <div class="max-w-2xl">
          <p
            class="border-border text-muted-foreground mb-4 inline-flex items-center gap-2 rounded-full border px-3 py-1 text-xs font-medium"
          >
            <span class="inline-block size-1.5 rounded-full bg-green-500"
            ></span>
            开放 AI PM 职位机会、产品合作与早期想法交流 —
            <a
              href="#contact"
              class="text-foreground hover:text-accent underline decoration-dashed underline-offset-4"
              >联系我</a
            >
          </p>
          <h1 class="text-4xl font-bold tracking-tight sm:text-5xl">余文豪</h1>
          <div
            class="bg-accent mt-5 h-0.5 w-16 origin-left animate-[slideIn_600ms_ease-out_200ms_forwards]"
            style="transform: scaleX(0);"
          >
          </div>
          <p class="mt-4 text-lg font-medium sm:text-xl">
            我是一名 AI 产品经理，专注于智能体工作流、本体驱动系统和 AI
            原生产品工具。
          </p>
          <p class="text-muted-foreground mt-3 max-w-2xl">
            我擅长把模糊的业务问题转化为结构化产品概念、交互式原型和可复用交付系统。
          </p>
          <p class="mt-3 text-sm">
            <a
              href={getRelativeLocaleUrl(locale, "now")}
              class="text-accent hover:underline"
            >
              → 我现在在做什么
            </a>
          </p>
          <p class="text-muted-foreground mt-4 text-sm">从这里开始 →</p>
          <div class="mt-2 flex flex-wrap gap-3">
            <a
              href={getRelativeLocaleUrl(locale, "projects")}
              class="bg-accent text-accent-foreground inline-flex items-center gap-1.5 rounded-md px-5 py-2.5 text-sm font-medium transition-opacity hover:opacity-90"
            >
              查看项目
              <IconArrowRight class="size-4" />
            </a>
            <a
              href="https://wenhaoyu-bryan.github.io/AI-PM-Operating-Playbook/"
              target="_blank"
              rel="noopener noreferrer"
              class="border-border text-foreground hover:bg-accent/10 inline-flex items-center gap-1.5 rounded-md border px-5 py-2.5 text-sm font-medium transition-colors"
            >
              打开 AI PM Operating Playbook ↗
            </a>
            <a
              href={getRelativeLocaleUrl(locale, "posts")}
              class="border-border text-foreground hover:bg-accent/10 inline-flex items-center gap-1.5 rounded-md border px-5 py-2.5 text-sm font-medium transition-colors"
            >
              阅读文章
            </a>
          </div>
        </div>
        <img
          src="/profile-avatar.jpg"
          alt="余文豪 - AI 产品经理"
          width="152"
          height="152"
          class="border-border bg-muted/30 size-28 rounded-full border object-cover sm:size-36"
          loading="eager"
          decoding="async"
        />
      </div>
    </section>

    <!-- Featured -->
    <section class="border-border border-b py-10 sm:py-14">
      <h2 class="text-2xl font-semibold tracking-wide">精选内容</h2>
      <div class="mt-6 grid gap-4 sm:grid-cols-2">
        {
          featured.map(item => (
            <a
              href={item.href}
              class="border-border group hover:bg-accent/5 rounded-lg border p-5 transition-colors"
            >
              <h3 class="group-hover:text-accent text-lg font-medium">
                {item.title}
              </h3>
              <p class="text-muted-foreground mt-1.5 text-sm">
                {item.description}
              </p>
            </a>
          ))
        }
      </div>
    </section>

    <!-- Featured Projects -->
    <section class="border-border border-b py-10 sm:py-14">
      <h2 class="text-2xl font-semibold tracking-wide">项目</h2>
      <div class="mt-6 grid gap-4 sm:grid-cols-2">
        {
          projects.map(project => (
            <a
              href={project.href}
              class="border-border group hover:bg-accent/5 rounded-lg border p-5 transition-colors"
              {...(project.href.startsWith("http")
                ? { target: "_blank", rel: "noopener noreferrer" }
                : {})}
            >
              <div class="flex items-center justify-between">
                <h3 class="group-hover:text-accent text-lg font-medium">
                  {project.title}
                </h3>
                <span class="text-muted-foreground rounded-full border px-2.5 py-0.5 text-xs">
                  {project.status}
                </span>
              </div>
              <p class="text-muted-foreground mt-2 text-sm">
                {project.description}
              </p>
            </a>
          ))
        }
      </div>
    </section>

    <!-- What I Work On -->
    <section class="border-border border-b py-10 sm:py-14">
      <h2 class="text-2xl font-semibold tracking-wide">研究方向</h2>
      <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {
          topics.map(topic => (
            <div class="border-border rounded-lg border p-5">
              <h3 class="font-medium">{topic.title}</h3>
              <p class="text-muted-foreground mt-1.5 text-sm">
                {topic.description}
              </p>
            </div>
          ))
        }
      </div>
      <p class="mt-6 text-sm">
        <a
          href={getRelativeLocaleUrl(locale, "ai-stack")}
          class="text-accent hover:underline"
        >
          我如何编排这些工具 → 我的 AI 工具栈
        </a>
      </p>
    </section>

    <!-- Contact CTA -->
    <section id="contact" class="py-10 sm:py-14">
      <h2 class="text-2xl font-semibold tracking-wide">联系方式</h2>
      <p class="text-muted-foreground mt-2 max-w-xl">
        如果你对 AI 产品协作、本体驱动系统或增长实验感兴趣，欢迎联系。
      </p>
      <div class="mt-5 max-w-xl">
        <AskAI locale={locale} />
      </div>
      <div class="mt-5 flex flex-wrap gap-3">
        <button
          type="button"
          class="border-border text-foreground hover:bg-accent/10 inline-flex cursor-pointer items-center gap-1.5 rounded-md border px-4 py-2 text-sm font-medium transition-colors"
          data-copy-email="wenhaoyu.bryan@gmail.com"
        >
          Email
        </button>
        <a
          href="https://github.com/wenhaoyu-bryan"
          class="border-border text-foreground hover:bg-accent/10 inline-flex items-center gap-1.5 rounded-md border px-4 py-2 text-sm font-medium transition-colors"
          target="_blank"
          rel="noopener noreferrer"
        >
          GitHub
        </a>
        <a
          href="https://linkedin.com/in/wenhaoyu-bryan/"
          class="border-border text-foreground hover:bg-accent/10 inline-flex items-center gap-1.5 rounded-md border px-4 py-2 text-sm font-medium transition-colors"
          target="_blank"
          rel="noopener noreferrer"
        >
          LinkedIn
        </a>
        <a
          href="https://x.com/WENHAOYU8"
          class="border-border text-foreground hover:bg-accent/10 inline-flex items-center gap-1.5 rounded-md border px-4 py-2 text-sm font-medium transition-colors"
          target="_blank"
          rel="noopener noreferrer"
        >
          X
        </a>
        <a
          href="https://medium.com/@bryanyuwh"
          class="border-border text-foreground hover:bg-accent/10 inline-flex items-center gap-1.5 rounded-md border px-4 py-2 text-sm font-medium transition-colors"
          target="_blank"
          rel="noopener noreferrer"
        >
          Medium
        </a>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<script>
  import "@/scripts/homeReveal";

  document.addEventListener("astro:page-load", () => {
    document
      .querySelectorAll<HTMLButtonElement>("[data-copy-email]")
      .forEach(btn => {
        btn.addEventListener("click", async () => {
          const email = btn.dataset.copyEmail;
          if (!email) return;
          try {
            await navigator.clipboard.writeText(email);
            const original = btn.textContent;
            btn.textContent = "已复制!";
            setTimeout(() => {
              btn.textContent = original;
            }, 2000);
          } catch {
            window.location.href = `mailto:${email}`;
          }
        });
      });
  });
</script>
