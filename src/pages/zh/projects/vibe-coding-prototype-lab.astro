---
import { getRelativeLocaleUrl } from "astro:i18n";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Main from "@/components/Main.astro";
import Footer from "@/components/Footer.astro";
import FlowDiagram from "@/components/FlowDiagram.astro";
import config from "@/config";

const workflowSteps = [
  { label: "产品意图", note: "明确为什么" },
  { label: "约束与非目标", note: "圈定范围" },
  { label: "可运行原型", note: "小步生成", emphasis: true },
  { label: "行为审查", note: "不只看代码" },
  { label: "可复用模式", note: "重构沉淀" },
  { label: "Playbook", note: "记录学习", emphasis: true },
];

const snapshot = [
  { label: "角色", value: "产品经理，主导 PM-led 原型开发" },
  { label: "类型", value: "持续更新的公开实验室" },
  { label: "工具", value: "Claude Code · Cursor · LLM Pair Programming" },
  { label: "状态", value: "活跃 — 持续新增实验" },
];
---

<Layout
  title={`Vibe Coding Prototype Lab | ${config.site.title}`}
  description="探索 AI 产品经理如何借助 Claude Code、Cursor 和 LLM Pair Programming 把产品想法转化为原型、规格和可复用流程。"
>
  <Header />

  <Main pageTitle="Vibe Coding Prototype Lab" class="app-prose">
    <p class="text-muted-foreground text-sm">
      <a
        href={getRelativeLocaleUrl("en", "projects/vibe-coding-prototype-lab")}
        class="text-accent hover:underline"
      >
        Read this page in English
      </a>
    </p>

    <p class="text-muted-foreground text-lg">
      探索 AI 产品经理如何借助 Claude Code、Cursor 和 LLM Pair Programming
      把产品想法转化为原型、规格和可复用流程。
    </p>

    <div class="border-border mt-4 flex flex-wrap gap-2">
      <span class="rounded-full border px-3 py-1 text-xs font-medium">
        Claude Code
      </span>
      <span class="rounded-full border px-3 py-1 text-xs font-medium">
        Cursor
      </span>
      <span class="rounded-full border px-3 py-1 text-xs font-medium">
        LLM Pair Programming
      </span>
      <span class="rounded-full border px-3 py-1 text-xs font-medium">
        原型验证
      </span>
    </div>

    <div
      class="border-border bg-border mt-6 grid gap-px overflow-hidden rounded-lg border sm:grid-cols-2"
    >
      {
        snapshot.map(item => (
          <div class="bg-background p-4">
            <p class="text-muted-foreground text-xs font-medium tracking-wide uppercase">
              {item.label}
            </p>
            <p class="mt-1 text-sm">{item.value}</p>
          </div>
        ))
      }
    </div>

    <h2 class="mt-8 text-xl font-semibold">为什么这件事很重要</h2>
    <p>
      AI
      产品经理越来越需要从写抽象需求文档，转向能直接塑造可运行的产品行为。Vibe
      Coding 让 PM
      可以在要求工程团队投入全部资源之前，先验证产品逻辑、交互流程和技术假设。
    </p>

    <h2 class="mt-6 text-xl font-semibold">我用它来做什么</h2>
    <ul class="mt-2 space-y-2">
      <li>把粗糙的产品想法转化为可点击的原型</li>
      <li>将 PRD 转化为面向实现的规格说明</li>
      <li>探索架构边界和可行性</li>
      <li>测试 Agent 工作流和工具调用逻辑</li>
      <li>从私有产品实践中提取脱敏后的公开实验</li>
    </ul>

    <h2 class="mt-6 text-xl font-semibold">我的工作流</h2>
    <FlowDiagram
      steps={workflowSteps}
      caption="每一轮循环都以文档化、可复用的模式收尾 —— 原型是副产品，Playbook 才是资产。"
    />

    <h2 class="mt-6 text-xl font-semibold">成果与信号</h2>
    <ul class="mt-2 space-y-2">
      <li>
        <a
          href={getRelativeLocaleUrl("zh", "projects/prompt-to-ontology")}
          class="text-accent hover:underline">Prompt-to-Ontology</a
        > — 用这套工作流从零构建的全栈本体原型。
      </li>
      <li>
        <a
          href="https://wenhaoyu-bryan.github.io/AI-PM-Operating-Playbook/"
          class="text-accent hover:underline"
          target="_blank"
          rel="noopener noreferrer">AI PM Operating Playbook</a
        > — 交互式工具集，本身也是 Vibe Coding 的产物。
      </li>
      <li>
        本网站 — 通过 PM 主导的 LLM Pair Programming 在 Astro
        上设计、构建和迭代。
      </li>
      <li>
        工作流已沉淀为
        <a
          href={getRelativeLocaleUrl("zh", "playbook")}
          class="text-accent hover:underline">Playbook 方法论</a
        >。
      </li>
    </ul>

    <h2 class="mt-6 text-xl font-semibold">这不是什么</h2>
    <p>
      Vibe Coding
      不是为了替代专业工程团队，而是让产品经理能更早地澄清产品行为、减少需求歧义，并以更具体的原型和规格与工程团队协作。部分公司相关工作因数据权限约束无法公开，本站只展示脱敏后的实验和可复用流程。
    </p>

    <h2 class="mt-6 text-xl font-semibold">公开实验</h2>
    <ul class="mt-2 space-y-2">
      <li>
        <a
          href={getRelativeLocaleUrl("zh", "projects/prompt-to-ontology")}
          class="text-accent hover:underline"
        >
          Prompt-to-Ontology
        </a> — 本体驱动的企业 AI 原型
      </li>
      <li>
        <a
          href={getRelativeLocaleUrl("zh", "playbook")}
          class="text-accent hover:underline"
        >
          AI PM Operating Playbook
        </a> — 方法论与工作流
      </li>
      <li>更多脱敏原型（持续更新中）</li>
    </ul>

    <div class="mt-6 flex flex-wrap gap-3">
      <a
        href="https://github.com/wenhaoyu-bryan/prompt-to-ontology"
        class="bg-accent text-accent-foreground inline-flex items-center gap-1.5 rounded-md px-5 py-2.5 text-sm font-medium transition-opacity hover:opacity-90"
        target="_blank"
        rel="noopener noreferrer"
      >
        在 GitHub 查看 Prompt-to-Ontology
      </a>
      <a
        href={getRelativeLocaleUrl("zh", "playbook")}
        class="border-border text-foreground hover:bg-accent/10 inline-flex items-center gap-1.5 rounded-md border px-5 py-2.5 text-sm font-medium transition-colors"
      >
        阅读 Playbook
      </a>
      <a
        href="https://github.com/wenhaoyu-bryan"
        class="border-border text-foreground hover:bg-accent/10 inline-flex items-center gap-1.5 rounded-md border px-5 py-2.5 text-sm font-medium transition-colors"
        target="_blank"
        rel="noopener noreferrer"
      >
        GitHub 主页
      </a>
    </div>
  </Main>

  <Footer />
</Layout>
