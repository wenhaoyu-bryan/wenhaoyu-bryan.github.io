---
import { getRelativeLocaleUrl } from "astro:i18n";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Main from "@/components/Main.astro";
import Footer from "@/components/Footer.astro";
import FlowDiagram from "@/components/FlowDiagram.astro";
import ScreenshotGallery from "@/components/ScreenshotGallery.astro";
import type { Shot } from "@/components/ScreenshotGallery.astro";
import config from "@/config";

import dashboard from "@/assets/projects/prompt-to-ontology/dashboard.png";
import dataPipeline from "@/assets/projects/prompt-to-ontology/data-pipeline.png";
import ontologyManager from "@/assets/projects/prompt-to-ontology/ontology-manager.png";
import graph from "@/assets/projects/prompt-to-ontology/graph.png";
import analystAgent from "@/assets/projects/prompt-to-ontology/analyst-agent.png";
import reviewQueue from "@/assets/projects/prompt-to-ontology/review-queue.png";

const walkthrough: Shot[] = [
  {
    src: dashboard,
    alt: "运营本体运行时仪表盘",
    caption:
      "运营运行时 —— 46 个本体对象、116 条关系、5 条风险规则、324 条待审项。",
  },
  {
    src: dataPipeline,
    alt: "数据管线：选择、剖析、映射、校验、导入",
    caption:
      "数据管线 —— 剖析原始 CSV，将字段映射到本体类型，生成可审查的导入计划。",
  },
  {
    src: ontologyManager,
    alt: "本体 Schema 管理：对象类型、关系、规则、动作",
    caption: "本体 Schema —— 6 种对象类型、关系类型、校验规则与业务动作定义。",
  },
  {
    src: graph,
    alt: "交互式知识图谱浏览器",
    caption: "图谱浏览器 —— 推断出的知识图谱以带类型的对象和关系呈现。",
  },
  {
    src: analystAgent,
    alt: "分析 Agent 通过本体工具回答问题",
    caption:
      "分析 Agent —— 通过调用本体工具回答，而非凭空猜测；只提出可审查的动作建议。",
  },
  {
    src: reviewQueue,
    alt: "人工确认审查队列",
    caption:
      "审查队列 —— 低置信度候选项与 Agent 建议在写入图谱前等待人工确认。",
  },
];

const architectureSteps = [
  { label: "原始 CSV / 需求", note: "非结构化输入" },
  { label: "LLM Schema 推断", note: "推理层", emphasis: true },
  { label: "本体 Schema", note: "实体 · 关系 · 约束" },
  { label: "Neo4j 图数据库", note: "数据源" },
  { label: "NetworkX", note: "计算引擎" },
  { label: "ReAct Agent", note: "查询 + 动作建议", emphasis: true },
  { label: "人工确认", note: "HITL 业务动作" },
];

const snapshot = [
  { label: "角色", value: "产品经理 & 独立构建者" },
  { label: "类型", value: "公开案例 / 可运行原型" },
  { label: "技术栈", value: "Neo4j · NetworkX · LLM · ReAct Agent" },
  { label: "状态", value: "公开仓库，持续迭代" },
];
---

<Layout
  title={`Prompt-to-Ontology | ${config.site.title}`}
  description="案例研究：把模糊需求和原始 CSV 数据转化为可运营的知识图谱与 Agent 层 —— 本体 Schema 推断、Neo4j 与人工确认的业务动作。"
>
  <Header />
  <Breadcrumb />

  <Main pageTitle="Prompt-to-Ontology" class="app-prose">
    <p class="text-muted-foreground text-sm">
      <a
        href={getRelativeLocaleUrl("en", "projects/prompt-to-ontology")}
        class="text-accent hover:underline"
      >
        Read this page in English
      </a>
    </p>

    <p class="text-muted-foreground text-lg">
      一个公开实验：探索如何把模糊的产品需求、业务概念和表格数据转化为结构化本体资产和知识图谱，服务于企业
      AI 系统。
    </p>

    <div class="border-border mt-4 flex flex-wrap gap-2">
      <span class="rounded-full border px-3 py-1 text-xs font-medium">
        Knowledge Graphs
      </span>
      <span class="rounded-full border px-3 py-1 text-xs font-medium">
        Neo4j
      </span>
      <span class="rounded-full border px-3 py-1 text-xs font-medium">
        NetworkX
      </span>
      <span class="rounded-full border px-3 py-1 text-xs font-medium">
        ReAct Agent
      </span>
      <span class="rounded-full border px-3 py-1 text-xs font-medium">
        LLM Pair Programming
      </span>
    </div>

    <div
      class="border-border bg-border mt-6 grid gap-px overflow-hidden rounded-lg border sm:grid-cols-2"
    >
      {
        snapshot.map(item => (
          <div class="bg-background p-4">
            <p class="text-muted-foreground text-xs font-medium tracking-wide uppercase">
              {item.label}
            </p>
            <p class="mt-1 text-sm">{item.value}</p>
          </div>
        ))
      }
    </div>

    <h2 class="mt-8 text-xl font-semibold">问题背景</h2>
    <p>
      企业 AI
      系统经常失败，根本原因在于底层数据模型与真实业务逻辑不匹配。传统数据模型只展示表和列，但忽略了定义真实业务逻辑的关系、约束和操作。当
      AI Agent 构建在一个失真的数据模型之上时，它推理的是一个虚构的业务版本。
    </p>
    <p>
      本体（Ontology）不仅捕获实体和属性，还捕获关系、约束以及这些实体所能支撑的业务动作。对企业
      AI
      而言，这决定了你是拥有一个只会给通用答案的聊天机器人，还是一个能真正基于业务上下文进行操作的
      Agent。
    </p>

    <h2 class="mt-6 text-xl font-semibold">我的角色</h2>
    <p>
      这是一个 PM 主导的构建实验：我定义产品意图、架构边界和设计约束，使用 LLM
      Pair Programming（Claude
      Code）加速实现、调试和迭代。图谱建模什么、计算放在哪一层、Agent
      被允许做什么 —— 每一个架构决策本质上都是我做出并能够解释的产品决策。
    </p>

    <h2 class="mt-6 text-xl font-semibold">构建方式</h2>
    <p>
      Prompt-to-Ontology 接收原始 CSV 数据，将其转化为可交互的知识图谱。LLM
      推断本体 Schema —— 实体、关系、约束 —— 然后写入 Neo4j 图数据库。顶层是一个
      ReAct
      Agent，可以查询图谱并建议业务动作，所有操作都需要人工确认（Human-in-the-loop）。
    </p>
    <p>
      架构关注点分离：<strong>Neo4j</strong> 作为数据源，<strong
        >NetworkX</strong
      > 作为计算引擎，<strong>LLM</strong>
      作为推理层。三个解耦的系统，可以独立替换。
    </p>
    <FlowDiagram
      steps={architectureSteps}
      caption="端到端数据流：从原始表格数据到人工确认的业务动作。高亮阶段为 LLM 负责推理的环节。"
    />

    <h2 class="mt-8 text-xl font-semibold">产品实景</h2>
    <p>
      一个真实可运行的原型，端到端构建完成。点击任意截图可放大查看 ——
      这是宠物食品本体演示，跑通了从原始数据到 Agent
      建议、再到人工确认动作的完整流程。
    </p>
    <ScreenshotGallery images={walkthrough} />

    <div
      class="border-border bg-muted/30 mt-6 flex flex-col gap-3 rounded-lg border p-5 sm:flex-row sm:items-center sm:justify-between"
    >
      <div>
        <p class="font-medium">在 3D 中探索这套本体</p>
        <p class="text-muted-foreground text-sm">
          将知识图谱作为可交互的 3D 场景来探索 ——
          自由旋转、缩放，并查看每一个实体与关系（英文界面）。
        </p>
      </div>
      <a
        href={getRelativeLocaleUrl("en", "projects/ontology-graph")}
        class="bg-accent text-accent-foreground inline-flex shrink-0 items-center gap-1.5 rounded-md px-5 py-2.5 text-sm font-medium transition-opacity hover:opacity-90"
      >
        进入 3D 图谱 &rarr;
      </a>
    </div>

    <h2 class="mt-8 text-xl font-semibold">关键洞察</h2>
    <p>
      事实表是节点，不是边。订单不是客户和产品之间的关系 ——
      它是一个独立实体，通过两条独立的边分别连接到客户和产品。搞错这一点，整个图拓扑就会崩塌。
    </p>
    <p>
      没有 Action
      按钮的知识图谱只是一张好看的图。每种节点类型都有基于当前状态计算的上下文敏感操作
      —— 一个低库存节点会触发「创建采购单」按钮。
    </p>

    <h2 class="mt-6 text-xl font-semibold">成果与信号</h2>
    <ul class="mt-2 space-y-2">
      <li>
        一个可运行的全栈原型：输入 CSV，输出带有 Agent
        动作建议的可运营知识图谱，代码在公开 GitHub 仓库中。
      </li>
      <li>
        一套可复用的认知框架：数据模型、Schema
        和本体之间的区别；「看一个图」和「通过图来运营业务」之间的本质差异。
      </li>
      <li>
        方法论被提炼为
        <a
          href={getRelativeLocaleUrl("zh", "playbook")}
          class="text-accent hover:underline">Playbook 方法论页面</a
        >，并整理成一篇
        <a
          href="/posts/building-ontology-os"
          class="text-accent hover:underline">长文复盘</a
        >。
      </li>
    </ul>

    <div class="mt-6 flex flex-wrap gap-3">
      <a
        href="https://github.com/wenhaoyu-bryan/prompt-to-ontology"
        class="bg-accent text-accent-foreground inline-flex items-center gap-1.5 rounded-md px-5 py-2.5 text-sm font-medium transition-opacity hover:opacity-90"
        target="_blank"
        rel="noopener noreferrer"
      >
        在 GitHub 上查看
      </a>
      <a
        href="/posts/building-ontology-os"
        class="border-border text-foreground hover:bg-accent/10 inline-flex items-center gap-1.5 rounded-md border px-5 py-2.5 text-sm font-medium transition-colors"
      >
        阅读相关博文
      </a>
    </div>
  </Main>

  <Footer />
</Layout>
