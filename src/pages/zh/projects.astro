---
import { getRelativeLocaleUrl } from "astro:i18n";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Main from "@/components/Main.astro";
import Footer from "@/components/Footer.astro";
import config from "@/config";
import { getProjects } from "@/data/projects";

const projects = getProjects("zh");
---

<Layout
  title={`项目 | ${config.site.title}`}
  description="公开项目与实验：Prompt-to-Ontology、AI PM Operating Playbook、Vibe Coding Prototype Lab 和 SEO/GEO Growth Lab。"
>
  <Header />

  <Main pageTitle="项目" class="app-prose">
    <p class="text-muted-foreground text-sm">
      <a
        href={getRelativeLocaleUrl("en", "projects")}
        class="text-accent hover:underline"
      >
        Read in English
      </a>
    </p>

    <p>
      这里整理了我公开展示的项目、原型和方法论实验，主要围绕 AI
      产品管理、本体驱动系统、Vibe Coding 和 SEO/GEO 增长展开。
    </p>

    <p class="text-muted-foreground text-sm">
      部分工作来自真实业务实践，但出于数据权限和商业保密要求，网站只展示抽象后的方法论和可公开项目，不展示内部系统、客户数据或公司机密。
    </p>

    <div class="mt-8 grid gap-6">
      {
        projects.map(project => (
          <a
            href={project.href}
            class="border-border group hover:bg-accent/5 rounded-lg border p-6 transition-colors"
            {...(project.href.startsWith("http")
              ? { target: "_blank", rel: "noopener noreferrer" }
              : {})}
          >
            <div class="flex items-center justify-between">
              <h2 class="group-hover:text-accent text-xl font-semibold">
                {project.title}
              </h2>
              <span class="text-muted-foreground rounded-full border px-2.5 py-0.5 text-xs">
                {project.status}
              </span>
            </div>
            <p class="text-muted-foreground mt-2">{project.description}</p>
            <div class="mt-3 flex flex-wrap gap-2">
              {project.tags.map(tag => (
                <span class="bg-muted rounded-full px-2.5 py-0.5 text-xs">
                  {tag}
                </span>
              ))}
            </div>
          </a>
        ))
      }
    </div>
  </Main>

  <Footer />
</Layout>
