---
import { getRelativeLocaleUrl } from "astro:i18n";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Main from "@/components/Main.astro";
import Footer from "@/components/Footer.astro";
import config from "@/config";

const locale = Astro.currentLocale ?? config.site.lang;

// 每次改动本页内容时，更新这个日期。
const lastUpdated = "2026 年 7 月 20 日";

const building = [
  "作为产品经理，带领一个企业级 Agent 平台从 0 到 1——产品构思、PRD、竞品分析、客户反馈，以及用 Vibe Coding 做出、成为工程团队开发蓝图的原型。",
  "设计多智能体会话与编排者—工作者（orchestrator–worker）架构——让各有专长的智能体拆分任务、彼此协同，并保持可治理。",
  "把这个网站发展成一个双语的 AI 产品管理作品集与知识中心。",
  "把我日常在用的工具链，沉淀为一套有文档、可复用的 AI PM 工作操作系统。",
];

const exploring = [
  "Ontology 和知识图谱如何让企业 AI 更可靠、更可运营。",
  "PM 如何用 Vibe Coding 更快验证想法，并给工程团队交付一份可运行的蓝图。",
  "AI 搜索（GEO）如何改变产品被发现和被采用的方式。",
  "跨 AI 工具栈的自动化模型路由策略，以及诚实的成本效益追踪。",
];

const shipped = [
  "企业级 Agent 平台的「当前工作」页面——对我正在主导的平台做一次不涉密的介绍，聚焦方法论与能力，而非内部细节。",
  "把 Growth Lab 重构成一本公开的实验笔记——方法论优先，并把这个网站作为「实验 01」在跑。",
  "我的 AI 工具栈——一个记录我如何编排编码智能体、对话模型和自建工具的页面，附带诚实的能力边界。",
  "AI PM Manifesto——一个暗色电影感的单页前端/UX 作品展示，基于 Astro、GSAP、Lenis 构建。",
  "Prompt-to-Ontology 项目里的交互式 3D 本体图谱。",
  "网站非博客页面的完整中文本地化。",
];
---

<Layout
  title={`Now · 我在做什么 — ${config.site.title}`}
  description="Wenhao Yu 现在正在专注什么——当前项目、正在探索的方向，以及最近上线的工作。遵循 nownownow.com 惯例的 now 页面。"
>
  <Header />
  <Breadcrumb />

  <Main pageTitle="Now · 我在做什么" class="app-prose">
    <p class="text-muted-foreground text-sm">
      <a
        href={getRelativeLocaleUrl("en", "now")}
        class="text-accent hover:underline"
      >
        Read this page in English
      </a>
    </p>
    <p class="text-muted-foreground text-sm">
      我现在正在专注的事。这是一个
      <a href="https://nownownow.com/about" class="text-accent hover:underline"
        >now 页面</a
      >——一张快照，而不是变更日志。最后更新于 {lastUpdated}。
    </p>

    <h2 class="mt-8 text-xl font-semibold">正在构建</h2>
    <ul class="mt-2 space-y-2">
      {building.map(item => <li>{item}</li>)}
    </ul>

    <h2 class="mt-8 text-xl font-semibold">正在探索</h2>
    <ul class="mt-2 space-y-2">
      {exploring.map(item => <li>{item}</li>)}
    </ul>

    <h2 class="mt-8 text-xl font-semibold">最近上线</h2>
    <ul class="mt-2 space-y-2">
      {shipped.map(item => <li>{item}</li>)}
    </ul>

    <div class="border-border mt-10 rounded-lg border p-6">
      <h2 class="text-lg font-semibold">其他去处</h2>
      <div class="mt-3 flex flex-wrap gap-3">
        <a
          href={getRelativeLocaleUrl(locale, "ai-stack")}
          class="text-accent hover:underline"
        >
          我的 AI 工具栈
        </a>
        <a
          href={getRelativeLocaleUrl(locale, "projects")}
          class="text-accent hover:underline"
        >
          项目
        </a>
        <a
          href={getRelativeLocaleUrl(locale, "about")}
          class="text-accent hover:underline"
        >
          关于
        </a>
      </div>
    </div>
  </Main>

  <Footer />
</Layout>
