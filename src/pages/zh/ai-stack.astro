---
import { getRelativeLocaleUrl } from "astro:i18n";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Main from "@/components/Main.astro";
import Footer from "@/components/Footer.astro";
import FlowDiagram from "@/components/FlowDiagram.astro";
import config from "@/config";

const locale = Astro.currentLocale ?? config.site.lang;

const workflow = [
  {
    stage: "产品构思",
    tools: "ChatGPT（主力）+ Gemini（发散补充）",
    note: "在写任何代码之前，先做产品框架、头脑风暴，把模糊想法结构化。",
  },
  {
    stage: "原型开发",
    tools: "Claude Code CLI（主力）+ Cursor（辅助）",
    note: "规格驱动的构建流程：头脑风暴 → 书面计划 → 实现 → 评审，大部分在 Claude Code 的结构化技能工作流里完成。",
  },
  {
    stage: "高难度 Debug",
    tools: "Claude Opus / 前沿推理模型",
    note: "一个 bug 撑过两轮修复还没解决，就切换到手头最强的代码模型，而不是硬试。",
  },
  {
    stage: "前端与 CMS 页面",
    tools: "Codex app",
    note: "营销页和 CMS 类工作，视觉迭代速度比深度推理更重要。",
  },
  {
    stage: "日常运转",
    tools: "Agent 工作流 + MCP 工具",
    note: "调研、笔记和重复性任务都跑在 Agent 循环里，而不是靠脑子记。",
  },
];

// 工作流卡片上方 line-art 流水线总览的简短节点标签。
const flowSteps = [
  { label: "构思", note: "立意" },
  { label: "原型", note: "构建", emphasis: true },
  { label: "调试", note: "攻坚" },
  { label: "前端 / CMS", note: "迭代" },
  { label: "日常运转", note: "自动化" },
];

const models = [
  {
    model: "ChatGPT",
    role: "产品构思（主力）",
    why: "发散思考和结构化模糊产品想法的能力最强。",
  },
  {
    model: "Gemini",
    role: "构思（辅助）",
    why: "提供一个偏好不同的第二意见，用于探索。",
  },
  {
    model: "Claude（Opus 级）",
    role: "高难度 Debug 与代码评审",
    why: "问题真正困难时，代码质量最好。",
  },
  {
    model: "DeepSeek",
    role: "高性价比代码生成",
    why: "输出出色而价格只有前沿模型的零头——常规编码的默认选择。",
  },
  {
    model: "Kimi",
    role: "长上下文辅助",
    why: "大代码库或长文档场景下性价比高。",
  },
  {
    model: "轻量快速模型",
    role: "Agent 日常对话层",
    why: "个人 Agent 的对话层优先考虑响应速度和稳定性，而非峰值智力。",
  },
];

const boundaries = [
  {
    area: "前端原型",
    current: "Astro + React + shadcn/Radix 体系熟练，1–2 天可交付可交互原型。",
    next: "后端联调与真实数据流。",
  },
  {
    area: "企业级中台（Vue）",
    current: "能维护和扩展 Vue 3 monorepo 中台体系，但不是主力赛道。",
    next: "更深入的组件定制。",
  },
  {
    area: "动画与 3D",
    current: "GSAP + Lenis 滚动驱动动画熟练；Three.js（R3F）达到基础可用水平。",
    next: "复杂交互式 3D 场景。",
  },
  {
    area: "AI 工具编排",
    current: "3 个编程工具、多个 Agent 平台、7+ 模型之间无缝切换。",
    next: "自动路由策略与成本效益量化追踪。",
  },
  {
    area: "知识管理",
    current: "双轨体系：持久化长文档知识库 + 日常 markdown wiki。",
    next: "定期 lint，保持两条轨道的健康。",
  },
];
---

<Layout
  title={`我的 AI 工具栈 | ${config.site.title}`}
  description="一个 AI 产品经理如何编排编码智能体、对话模型和自建工具——真实的工具栈、路由逻辑，以及诚实的能力边界。"
>
  <Header />
  <Breadcrumb />

  <Main pageTitle="我的 AI 工具栈" class="app-prose">
    <p class="text-muted-foreground text-sm">
      <a
        href={getRelativeLocaleUrl("en", "ai-stack")}
        class="text-accent hover:underline"
      >
        Read this page in English
      </a>
    </p>
    <p>
      我不用一个 AI 工具干所有事。运转原则是<strong>Harness Engineering</strong>
      ：让每个工具做它最擅长的事，并设计好工具之间的交接。这个页面记录我每天真实在跑的工具栈——以及它的边界在哪里。
    </p>
    <p class="text-muted-foreground text-sm">
      雇主与客户相关的工作在此有意做了抽象，只点名公开上线的项目。模型只写产品线不写版本号——路由逻辑比任何一次版本发布都活得久。
    </p>

    <h2 class="mt-8 text-xl font-semibold">工作流</h2>
    <p>每个项目都经过同一条流水线，不同工具负责不同阶段：</p>
    <FlowDiagram steps={flowSteps} />
    <div class="mt-4 space-y-3">
      {
        workflow.map((step, i) => (
          <div class="border-border rounded-lg border p-5">
            <div class="flex items-baseline gap-3">
              <span class="text-accent font-mono text-sm">
                {String(i + 1).padStart(2, "0")}
              </span>
              <div>
                <h3 class="font-medium">{step.stage}</h3>
                <p class="text-accent mt-0.5 text-sm">{step.tools}</p>
                <p class="text-muted-foreground mt-1.5 text-sm">{step.note}</p>
              </div>
            </div>
          </div>
        ))
      }
    </div>

    <h2 class="mt-8 text-xl font-semibold">编程工具</h2>
    <ul class="mt-2 space-y-2">
      <li>
        <strong>Claude Code CLI —— 主力。</strong>
        承担大部分前后端工作，配有 80+ 技能和「头脑风暴-计划-实现-评审」的结构化工作流。本站、
        <a
          href="https://wenhaoyu-bryan.github.io/AI-PM-Operating-Playbook/"
          class="text-accent hover:underline">AI PM Operating Playbook</a
        >、
        <a
          href="https://wenhaoyu-bryan.github.io/AI-PM-Manifesto/"
          class="text-accent hover:underline">AI PM Manifesto</a
        >
        和
        <a
          href={getRelativeLocaleUrl(locale, "projects/prompt-to-ontology")}
          class="text-accent hover:underline">Prompt-to-Ontology</a
        >
        都主要用它构建。
      </li>
      <li>
        <strong>Cursor —— 辅助。</strong>
        Auto 模式做快速原型迭代，特定场景手动切换到对应强项的模型。
      </li>
      <li>
        <strong>Codex app —— 场景化。</strong>
        前端和 CMS 页面工作，视觉迭代速度比架构深度更重要的时候用它。
      </li>
    </ul>

    <h2 class="mt-8 text-xl font-semibold">模型分工</h2>
    <div class="mt-4 space-y-3">
      {
        models.map(m => (
          <div class="border-border rounded-lg border p-5">
            <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1">
              <h3 class="font-medium">{m.model}</h3>
              <span class="text-accent text-sm">{m.role}</span>
            </div>
            <p class="text-muted-foreground mt-1.5 text-sm">{m.why}</p>
          </div>
        ))
      }
    </div>

    <h2 class="mt-8 text-xl font-semibold">构建栈</h2>
    <ul class="mt-2 space-y-2">
      <li>
        <strong>前端（主力）：</strong>Astro + React、Tailwind CSS、基于 Radix
        原语的 shadcn/ui
      </li>
      <li>
        <strong>企业级中台：</strong>Vue 3 + pnpm monorepo 中台框架（turborepo
        工具链）
      </li>
      <li>
        <strong>后端：</strong>Python + FastAPI，图谱/本体工作用 Neo4j +
        NetworkX，API 自动化用 Node.js
      </li>
      <li>
        <strong>动效与 3D：</strong>GSAP + Lenis 做滚动叙事，React Three Fiber
        做 3D
      </li>
      <li>
        <strong>部署：</strong>GitHub Pages 和 Vercel（CI
        自动部署），涉及真实后端时用 Docker Compose
      </li>
    </ul>

    <h2 class="mt-8 text-xl font-semibold">Agent 平台产品设计（0 → 1）</h2>
    <p>
      这套工具栈最重的证明不是业余项目。在现在的工作中，我作为产品经理把一个企业级
      Agent
      平台从零带到上线：从第一天的产品构思、PRD、竞品分析、客户反馈收集，到用
      Vibe Coding
      做出原型、成为工程团队开发所依据的蓝图。产品属于雇主，这里不出现名称与细节——只讲设计模式，那才是可迁移的部分。
    </p>
    <p>我主导的 agentic 设计决策：</p>
    <ul class="mt-2 space-y-2">
      <li>
        <strong>双模态架构：</strong>面向一线用户的业务工作台 +
        面向构建者的开发者后台，一键切换——同一个平台要让两种受众读出完全不同的体验
      </li>
      <li>
        <strong>分层资产模型：</strong>工具（原子调用）→
        技能（最小可执行能力单元）→ Agent（模型 + 提示词 + 知识 + 数据 + 工具 +
        技能），层层版本化管理，专家经验不随人员流动而流失
      </li>
      <li>
        <strong>对话生成技能：</strong
        >业务人员用自然语言描述需求，系统主动追问澄清、实时渲染执行步骤的逻辑蓝图，然后把代码、配置和说明文档一起生成
      </li>
      <li>
        <strong>治理先行：</strong
        >开发/生产沙箱隔离、模拟执行、高风险操作人工审批、能力开关、发布审查——未经检查的
        AI 产出永远不直接触碰真实业务系统
      </li>
      <li>
        <strong>有据可依的配置：</strong>Agent
        挂载知识库与术语库，让输出符合企业规范用语；技能可勾选「执行前人工确认」，主动反问与联网搜索均为显式开关
      </li>
      <li>
        <strong>自动化编排：</strong>接口回调、消息队列、定时任务三种触发方式 +
        可视化流程画布，低置信度分支转人工审批而不是靠猜
      </li>
    </ul>

    <h2 class="mt-8 text-xl font-semibold">编码之外</h2>
    <ul class="mt-2 space-y-2">
      <li>
        <strong>双轨知识管理：</strong>本地部署的长文档知识库（MCP 接入）+
        串联日常碎片的 markdown wiki——竞品截图、论文、Prompt 都进这里
      </li>
      <li>
        <strong>MCP 集成：</strong>浏览器自动化和网页抓取工具接入 Agent 循环
      </li>
      <li>
        <strong>企业 AI 赋能：</strong>面向战略、财务、法务等非技术团队做过 4
        场内部培训，推广 Agent 工作流
      </li>
    </ul>

    <h2 class="mt-8 text-xl font-semibold">诚实的能力边界</h2>
    <p>只列长处的工具栈页面是营销。真实的边界在这里：</p>
    <div class="mt-4 space-y-3">
      {
        boundaries.map(b => (
          <div class="border-border rounded-lg border p-5">
            <h3 class="font-medium">{b.area}</h3>
            <p class="text-muted-foreground mt-1.5 text-sm">{b.current}</p>
            <p class="mt-1.5 text-sm">
              <span class="text-accent font-medium">下一步：</span>
              <span class="text-muted-foreground">{b.next}</span>
            </p>
          </div>
        ))
      }
    </div>

    <p class="text-muted-foreground mt-8 text-sm">
      核心原则：找到最适合自己的组合，持续用下去，并确保它一直配得上自己的位置。
    </p>

    <div class="border-border mt-10 rounded-lg border p-6">
      <h2 class="text-lg font-semibold">相关</h2>
      <div class="mt-3 flex flex-wrap gap-3">
        <a
          href={getRelativeLocaleUrl(locale, "playbook/harness-engineering")}
          class="text-accent hover:underline"
        >
          Harness Engineering 方法论
        </a>
        <a
          href={getRelativeLocaleUrl(locale, "playbook/vibe-coding")}
          class="text-accent hover:underline"
        >
          Vibe Coding 方法论
        </a>
        <a
          href={getRelativeLocaleUrl(locale, "projects")}
          class="text-accent hover:underline"
        >
          项目
        </a>
      </div>
    </div>
  </Main>

  <Footer />
</Layout>
