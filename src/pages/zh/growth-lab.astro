---
import { getRelativeLocaleUrl } from "astro:i18n";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Main from "@/components/Main.astro";
import Footer from "@/components/Footer.astro";
import config from "@/config";

type Experiment = {
  number: string;
  title: string;
  status: string;
  hypothesis: string;
  built: string[];
  measuring: string;
  openQuestions: string[];
};

const experiments: Experiment[] = [
  {
    number: "01",
    title: "把本站当作 GEO 试验场",
    status: "进行中",
    hypothesis:
      "一个为机器可读性而打造的静态站点——干净的元数据、结构化数据、面向 AI 的内容端点——会比普通博客更容易被 AI 回答引擎准确读取和引用。",
    built: [
      "构建时从站点渲染的同一数据源拼装出 llms.txt（索引）与 llms-full.txt（全量内容）两个端点",
      "用 satori 动态生成 OG 图，让每个页面分享出去都是带标题的卡片，而不是一条干瘪的链接",
      "输出 JSON-LD 结构化数据（Person、WebSite、BlogPosting），让搜索和回答引擎能无歧义地解析身份与内容",
      "提供预填 llms-full 内容的「在 Claude / ChatGPT 中了解我」深链",
    ],
    measuring:
      "被索引的页面数、小众 AI PM 查询下的自然曝光，以及当被问到我时 AI 搜索工具是否引用得准确。",
    openQuestions: [
      "llms-full.txt 是否真的改变了 AI 引擎概括我的准确度，还是被直接忽略？",
      "哪些结构化数据类型真正影响回答引擎的引用，而不只是传统搜索摘要？",
      "产品内容该怎么写，才能让人和回答引擎第一遍就都读懂？",
    ],
  },
];
---

<Layout
  title={`Growth Lab · 公开增长实验笔记 — ${config.site.title}`}
  description="一本公开的 SEO 与 GEO 增长实验笔记——从在 Leiga 搭建的 SEO 基础，到把这个站点当作 AI 搜索的试验场。"
>
  <Header />
  <Breadcrumb />

  <Main pageTitle="Growth Lab" class="app-prose">
    <p class="text-muted-foreground text-sm">
      <a
        href={getRelativeLocaleUrl("en", "growth-lab")}
        class="text-accent hover:underline"
      >
        Read this page in English
      </a>
    </p>
    <p>
      Growth Lab
      是一本公开的增长实验笔记。与其抽象地谈增长方法论，我更愿意把实验放在明处做——先从我完全掌控的这个站点开始。
    </p>
    <p>
      每一条记录都走同一个循环：给出<strong>假设</strong>，<strong>构建</strong
      >能验证它的最小东西，想清楚要<strong>衡量</strong
      >什么，再记下它带出的<strong>开放问题</strong>。主线是
      GEO——生成式回答引擎正在如何改变自然增长——以及随之而来的机器可读、结构化内容方法。
    </p>

    <h2 class="mt-8 text-xl font-semibold">实验日志</h2>
    <div class="mt-4 space-y-6">
      <article class="border-border rounded-lg border p-6">
        <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1">
          <span class="text-accent text-sm font-medium">实验 00</span>
          <h3 class="text-lg font-medium">在 Leiga 搭建 SEO 基础</h3>
          <span
            class="border-border text-muted-foreground rounded-full border px-2.5 py-0.5 text-xs whitespace-nowrap"
          >
            已结束 · 2024 年 8 月
          </span>
        </div>
        <div class="mt-4 space-y-4">
          <div>
            <span class="text-accent text-sm font-medium">当时的处境</span>
            <p class="text-muted-foreground mt-1">
              <a
                href="https://leiga.com"
                target="_blank"
                rel="noopener noreferrer"
                class="text-accent hover:underline">Leiga</a
              > 是一款 AI 驱动的项目管理 SaaS，当时几乎没有任何自然搜索的可见性，一切要从零开始。我在
              2024 年 5 月到 8 月加入 Product Growth & Development 团队，搭建一个成长中的
              SaaS 要被搜索发现所需的基础——并且让这些基础足够扎实，在我离开之后还能继续起作用。
            </p>
          </div>
          <div>
            <span class="text-accent text-sm font-medium">我构建了什么</span>
            <ul class="text-muted-foreground mt-1 list-disc space-y-1 pl-5">
              <li>
                技术 SEO 基建——sitemap 与 robots 配置、canonical 规范化
                URL、重定向治理，以及可抓取性和收录问题的修复。
              </li>
              <li>
                元数据体系——跨页面类型统一的 title / description 模式与 Open
                Graph 标签。
              </li>
              <li>
                结构化数据——在关键页面类型上部署 schema.org
                标记，让搜索与回答引擎能无歧义地解析。
              </li>
              <li>
                内容架构——URL 结构、内部链接，以及一套页面类型分类：<a
                  href="https://www.leiga.com/use-case-product-manager"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-accent hover:underline">用例页</a
                >、<a
                  href="https://www.leiga.com/feature"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-accent hover:underline">功能页</a
                >、<a
                  href="https://www.leiga.com/resources"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-accent hover:underline">Resources</a
                >和<a
                  href="https://www.leiga.com/compare"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-accent hover:underline">对比页</a
                >。
              </li>
              <li>
                文档站——重建了 Leiga 的产品指南与帮助中心（<a
                  href="https://guide.leiga.com"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-accent hover:underline">guide.leiga.com</a
                >）。
              </li>
              <li>
                程序化落地页基建——可跨关键词族规模化的模板化页面系统，例如<a
                  href="https://www.leiga.com/free-tools"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-accent hover:underline">免费工具页</a
                >，这些工具的内容和工具名的关键词规划是我和研发团队一起做的。
              </li>
              <li>
                关键词研究与关键词到页面的映射——决定哪些页面应该存在、每个页面各自主打什么。
              </li>
              <li>内容分发——负责已发布文章在社交媒体上的推广。</li>
              <li>
                度量搭建——Search Console
                与分析工具的埋点，用来追踪这些工作（只是搭建本身——绝不涉及数据显示了什么）。
              </li>
            </ul>
            <p class="text-muted-foreground mt-2 text-sm">
              上面的链接只是各页面类型的线上实例，并不代表它们当前的表现或归属。
            </p>
          </div>
          <div>
            <span class="text-accent text-sm font-medium">值得记下的判断</span>
            <ul class="text-muted-foreground mt-1 list-disc space-y-1 pl-5">
              <li>
                凡是能按关键词族规模化的（免费工具页、对比页）就用模板化系统，只有真正需要观点表达的页面才手写编辑内容。
              </li>
              <li>
                先打地基再上量：先定好
                canonical、元数据模式和内部链接规则，让之后发布的每个页面都自动继承，而不必事后返工。
              </li>
            </ul>
          </div>
          <div>
            <span class="text-accent text-sm font-medium">它教会了我什么</span>
            <ul class="text-muted-foreground mt-1 list-disc space-y-1 pl-5">
              <li>
                SEO
                基础设施是一个产品面，而不是营销清单上的一个勾——它和你设计、维护的任何系统一样，有
                schema、模板和边界情况。
              </li>
              <li>
                内部链接就是信息架构：决定哪些页面存在、它们如何互相连接，和设计一个产品的导航是同一种功夫。
              </li>
              <li>
                地基会在你离开之后持续复利——我回头去看，大部分 SEO
                工作都还在原处，这正是我用「至今仍在线上」而不是某个流量数字来作为成果的原因。
              </li>
              <li>
                这是 2024
                年、在回答引擎重塑发现方式之前的工作——而这道缺口正是实验 01
                接着去探索的。
              </li>
            </ul>
          </div>
          <div>
            <span class="text-accent text-sm font-medium"
              >这里为什么没有数字</span
            >
            <p class="text-muted-foreground mt-1">
              表现数据属于
              Leiga，所以这个实验室只发布我自己拥有的数字——这里描述的是工作本身，且经过了公司的许可；结果归他们去公布。
            </p>
          </div>
        </div>
      </article>
      {
        experiments.map(exp => (
          <article class="border-border rounded-lg border p-6">
            <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1">
              <span class="text-accent text-sm font-medium">
                实验 {exp.number}
              </span>
              <h3 class="text-lg font-medium">{exp.title}</h3>
              <span class="border-border text-muted-foreground rounded-full border px-2.5 py-0.5 text-xs whitespace-nowrap">
                {exp.status}
              </span>
            </div>
            <div class="mt-4 space-y-4">
              <div>
                <span class="text-accent text-sm font-medium">假设</span>
                <p class="text-muted-foreground mt-1">{exp.hypothesis}</p>
              </div>
              <div>
                <span class="text-accent text-sm font-medium">
                  我构建了什么
                </span>
                <ul class="text-muted-foreground mt-1 list-disc space-y-1 pl-5">
                  {exp.built.map(b => (
                    <li>{b}</li>
                  ))}
                </ul>
              </div>
              <div>
                <span class="text-accent text-sm font-medium">
                  我在衡量什么
                </span>
                <p class="text-muted-foreground mt-1">{exp.measuring}</p>
              </div>
              <div>
                <span class="text-accent text-sm font-medium">开放问题</span>
                <ul class="text-muted-foreground mt-1 list-disc space-y-1 pl-5">
                  {exp.openQuestions.map(q => (
                    <li>{q}</li>
                  ))}
                </ul>
              </div>
            </div>
          </article>
        ))
      }
    </div>

    <div class="border-border mt-10 rounded-lg border p-6">
      <h2 class="text-lg font-semibold">相关链接</h2>
      <div class="mt-3 flex flex-wrap gap-3">
        <a
          href={getRelativeLocaleUrl("zh", "posts")}
          class="text-accent hover:underline"
        >
          文章
        </a>
        <a
          href={getRelativeLocaleUrl("zh", "projects")}
          class="text-accent hover:underline"
        >
          项目
        </a>
        <a
          href={getRelativeLocaleUrl("zh", "playbook/seo-to-geo")}
          class="text-accent hover:underline"
        >
          SEO to GEO Playbook
        </a>
      </div>
    </div>
  </Main>

  <Footer />
</Layout>
