---
import { getRelativeLocaleUrl } from "astro:i18n";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Main from "@/components/Main.astro";
import Footer from "@/components/Footer.astro";
import config from "@/config";

const experiments = [
  {
    hypothesis:
      "一个结构良好、meta、sitemap 和内容架构都到位的静态站点，能够在小众的 AI PM 关键词上取得排名。",
    built: "这个基于 Astro + GitHub Pages 的个人网站。",
    measured: "自然流量、被索引的页面数、AI 搜索引用。",
    next: "发布更多内容，追踪 GEO 表现。",
  },
  {
    hypothesis:
      "发布 llms.txt / llms-full.txt（llmstxt.org 惯例）能让 AI 回答引擎更容易读取并准确引用本站——相当于面向 GEO 的 sitemap。",
    built:
      "构建时生成 llms.txt（索引）和 llms-full.txt（全量内容）两个端点，从站点渲染的同一数据源拼装；并提供预填该内容的「在 Claude / ChatGPT 中了解我」深链。",
    measured: "AI 搜索引用、来自 AI 聊天工具的引荐流量。",
    next: "观察 AI 引擎是否随时间更准确地引用本站。",
  },
];
---

<Layout
  title={`Growth Lab | ${config.site.title}`}
  description="Growth Lab：关于 SEO、GEO、B2B 内容系统和 AI 搜索可见性的增长笔记与脱敏案例空间。"
>
  <Header />
  <Breadcrumb />

  <Main pageTitle="Growth Lab" class="app-prose">
    <p class="text-muted-foreground text-sm">
      <a
        href={getRelativeLocaleUrl("en", "growth-lab")}
        class="text-accent hover:underline"
      >
        Read this page in English
      </a>
    </p>
    <p>
      Growth Lab 是我用来沉淀 SEO、GEO、B2B 内容系统和 AI 搜索可见性思考的空间。
    </p>
    <p>
      我认为 AI
      产品不只是模型能力和功能设计，也需要分发、定位、信任和可持续的增长机制。懂增长的
      AI 产品经理，能更好地把产品决策和真实采用结果连接起来。
    </p>

    <h2 class="mt-8 text-xl font-semibold">实验方向</h2>
    <ul class="mt-2 space-y-2">
      <li>SEO 关键词架构</li>
      <li>GEO / AI 搜索可见性</li>
      <li>B2B 内容系统</li>
      <li>SaaS 工具站点想法</li>
      <li>个人站点作为 SEO/GEO 实验</li>
    </ul>

    <h2 class="mt-8 text-xl font-semibold">当前问题</h2>
    <ul class="mt-2 space-y-2">
      <li>产品内容应该如何写，才能同时被人和 AI 搜索引擎理解？</li>
      <li>B2B 公司如何建立主题权威？</li>
      <li>GEO 相比传统 SEO 改变了什么？</li>
      <li>AI 产品经理如何把产品思维和增长飞轮连接起来？</li>
    </ul>

    <h2 class="mt-8 text-xl font-semibold">隐私与脱敏原则</h2>
    <p>
      Growth Lab
      不会公开客户原始数据、公司后台截图、实习公司材料、内部分析看板、真实域名、完整关键词列表或敏感指标。
    </p>
    <p>
      如果未来分享过去的增长案例，我会使用匿名化、归一化或重新绘制的示意图。目标是分享可复用的增长思路，而不是暴露任何公司的私有业务信息。
    </p>

    <h2 class="mt-8 text-xl font-semibold">未来案例结构</h2>
    <p>后续成熟案例会尽量使用统一结构：</p>
    <ul class="mt-2 space-y-2">
      <li>背景</li>
      <li>问题</li>
      <li>假设</li>
      <li>我做了什么</li>
      <li>我衡量了什么</li>
      <li>我学到了什么</li>
      <li>可复用方法论</li>
    </ul>

    <h2 class="mt-6 text-xl font-semibold">实验日志</h2>
    <div class="mt-4 space-y-6">
      {
        experiments.map(exp => (
          <div class="border-border rounded-lg border p-6">
            <div class="space-y-3">
              <div>
                <span class="text-accent text-sm font-medium">假设</span>
                <p class="text-muted-foreground mt-1">{exp.hypothesis}</p>
              </div>
              <div>
                <span class="text-accent text-sm font-medium">
                  我构建了什么
                </span>
                <p class="text-muted-foreground mt-1">{exp.built}</p>
              </div>
              <div>
                <span class="text-accent text-sm font-medium">
                  我衡量了什么
                </span>
                <p class="text-muted-foreground mt-1">{exp.measured}</p>
              </div>
              <div>
                <span class="text-accent text-sm font-medium">下一步</span>
                <p class="text-muted-foreground mt-1">{exp.next}</p>
              </div>
            </div>
          </div>
        ))
      }
    </div>

    <div class="border-border mt-10 rounded-lg border p-6">
      <h2 class="text-lg font-semibold">相关链接</h2>
      <div class="mt-3 flex flex-wrap gap-3">
        <a
          href={getRelativeLocaleUrl("zh", "posts")}
          class="text-accent hover:underline"
        >
          文章
        </a>
        <a
          href={getRelativeLocaleUrl("zh", "projects")}
          class="text-accent hover:underline"
        >
          项目
        </a>
        <a
          href={getRelativeLocaleUrl("zh", "playbook/seo-to-geo")}
          class="text-accent hover:underline"
        >
          SEO to GEO Playbook
        </a>
      </div>
    </div>
  </Main>

  <Footer />
</Layout>
