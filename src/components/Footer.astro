---
import type { HTMLAttributes } from "astro/types";
import { getRelativeLocaleUrl } from "astro:i18n";
import Socials from "./Socials.astro";
import { useTranslations } from "@/i18n";
import config from "@/config";

type Props = {
  noMarginTop?: boolean;
} & HTMLAttributes<"footer">;

const { noMarginTop = false, class: className, ...attrs } = Astro.props;

const locale = Astro.currentLocale ?? config.site.lang;
const t = useTranslations(Astro.currentLocale);
const currentYear = new Date().getFullYear();
const nowLabel = locale === "zh" ? "Now · 我在做什么" : "Now";
---

<footer
  class:list={["app-layout", { "mt-auto": !noMarginTop }, className]}
  {...attrs}
>
  <div
    class="border-border flex flex-col items-center justify-between gap-2 border-t py-6 sm:flex-row-reverse sm:py-4"
  >
    <Socials />
    <div
      class="my-2 flex flex-col items-center gap-x-3 gap-y-1 text-sm sm:flex-row"
    >
      <span class="whitespace-nowrap">{t.footer.copyright}{currentYear}</span>
      <a
        href={getRelativeLocaleUrl(locale, "now")}
        class="text-accent hover:underline"
      >
        {nowLabel}
      </a>
    </div>
  </div>
</footer>
