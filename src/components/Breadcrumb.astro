---
import { getRelativeLocaleUrl } from "astro:i18n";
import { stripBase, stripLocale } from "@/utils/withBase";
import { useTranslations } from "@/i18n";
import config from "@/config";

const locale = Astro.currentLocale ?? config.site.lang;
const t = useTranslations(locale);
const isZh = locale === "zh";

// Strip base prefix and trailing slash, then locale prefix so segments
// reflect the logical page path only.
const pathWithoutBase = stripBase(Astro.url.pathname).replace(/\/+$/, "");
const currentUrlPath = stripLocale(pathWithoutBase, locale);

// Get url array from path
// eg: /tags/tailwindcss => ['tags', 'tailwindcss']
const breadcrumbList = currentUrlPath.split("/").slice(1).filter(Boolean);

const decodeSegment = (value: string) => {
  try {
    return decodeURIComponent(value);
  } catch {
    return value;
  }
};

const homeLabel = isZh ? "首页" : "Home";
const pageLabel = (n: number | string) =>
  isZh ? `第 ${n} 页` : `${t.pagination.page.toLowerCase()} ${n}`;

// Proper, human-readable labels for path slugs that would otherwise render as
// raw kebab-case (e.g. "enterprise-agent-platform"). Keyed by slug; zh falls
// back to en for brand/product names that stay the same in both locales.
const slugLabels: Record<string, { en: string; zh?: string }> = {
  // Section indexes
  projects: { en: "Projects", zh: "项目" },
  playbook: { en: "Playbook" },
  about: { en: "About", zh: "关于" },
  posts: { en: "Posts", zh: "文章" },
  tags: { en: "Tags", zh: "标签" },
  archives: { en: "Archives", zh: "归档" },
  search: { en: "Search", zh: "搜索" },
  // Standalone pages
  "ai-stack": { en: "AI Stack", zh: "AI 工具栈" },
  "growth-lab": { en: "Growth Lab" },
  now: { en: "Now" },
  // Playbook methodologies
  "prompt-to-ontology": { en: "Prompt-to-Ontology" },
  "agent-product-design": { en: "Agent Product Design", zh: "智能体产品设计" },
  "ai-native-prd": { en: "AI-Native PRD", zh: "AI 原生 PRD" },
  "harness-engineering": { en: "Harness Engineering" },
  "loop-engineering": { en: "Loop Engineering" },
  "prd-to-prototype": { en: "PRD to Prototype", zh: "从 PRD 到原型" },
  "seo-to-geo": { en: "SEO to GEO", zh: "从 SEO 到 GEO" },
  "vibe-coding": { en: "Vibe Coding" },
  // Projects
  "enterprise-agent-platform": {
    en: "Enterprise Agent Platform",
    zh: "企业级 Agent 平台",
  },
  "ontology-graph": { en: "Ontology Graph", zh: "本体图谱" },
};

// Resolve a path segment to a display label. `explicit` labels are already
// correctly cased, so the template skips the capitalize/lowercase transforms
// that exist only to prettify raw slugs (e.g. tag names).
const resolve = (segment: string): { label: string; explicit: boolean } => {
  const mapped = slugLabels[segment];
  if (mapped)
    return {
      label: isZh ? (mapped.zh ?? mapped.en) : mapped.en,
      explicit: true,
    };
  return { label: decodeSegment(segment), explicit: false };
};

// if breadcrumb is Home > Posts > [page] <etc>
// replace Posts with localized "Posts (page number)"
if (breadcrumbList[0] === "posts") {
  breadcrumbList.splice(
    0,
    2,
    `${resolve("posts").label} (${pageLabel(breadcrumbList[1] || 1)})`
  );
}

// if breadcrumb is Home > Tags > [tag] > [page] <etc>
// replace [tag] > [page] with localized [tag] (page number)
if (breadcrumbList[0] === "tags" && !isNaN(Number(breadcrumbList[2]))) {
  breadcrumbList.splice(
    1,
    3,
    `${decodeSegment(breadcrumbList[1])} ${
      Number(breadcrumbList[2]) === 1 ? "" : `(${pageLabel(breadcrumbList[2])})`
    }`
  );
}

const crumbs = breadcrumbList.map((segment, index) => {
  const { label, explicit } = resolve(segment);
  return {
    segment,
    label,
    explicit,
    index,
    isLast: index + 1 === breadcrumbList.length,
  };
});
---

<nav class="app-layout mt-8 mb-1" aria-label="breadcrumb">
  <ul
    class="font-light [&>li]:inline [&>li:not(:last-child)>a]:hover:opacity-100"
  >
    <li>
      <a
        href={getRelativeLocaleUrl(locale, "")}
        class="underline decoration-1 underline-offset-4 opacity-80"
      >
        {homeLabel}
      </a>
      <span aria-hidden="true" class="opacity-80">&raquo;</span>
    </li>
    {
      crumbs.map(crumb =>
        crumb.isLast ? (
          <li>
            <span
              class:list={[
                "opacity-75",
                crumb.explicit ? "" : "capitalize",
                { lowercase: !crumb.explicit && crumb.index > 0 },
              ]}
              aria-current="page"
            >
              {crumb.label}
            </span>
          </li>
        ) : (
          <li>
            <a
              href={getRelativeLocaleUrl(locale, crumb.segment)}
              class:list={[
                "underline decoration-1 underline-offset-4 opacity-70",
                crumb.explicit ? "" : "capitalize",
              ]}
            >
              {crumb.label}
            </a>
            <span aria-hidden="true" class="opacity-70">
              &raquo;
            </span>
          </li>
        )
      )
    }
  </ul>
</nav>
